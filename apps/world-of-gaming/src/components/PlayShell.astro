---
// Shared wrapper for every /play/<game> page. Renders the SEO meta + schema,
// the game heading, a back link, and the "More games" footer — all driven by
// the central catalog (lib/games.ts). The actual game markup goes in the slot.
import Layout from '../layouts/Layout.astro';
import { getGame, otherGames } from '../lib/games';
import { SITE_URL, SITE_NAME } from '../lib/config';

interface Props { slug: string }
const { slug } = Astro.props;
const game = getGame(slug)!;
const others = otherGames(slug);

const title = `${game.title} — Free ${game.category} Game | ${SITE_NAME}`;
const description = game.description;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: game.title,
  description,
  url: `${SITE_URL}/play/${game.slug}`,
  genre: game.category,
  applicationCategory: 'Game',
  operatingSystem: 'Any (web browser)',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
};
---
<Layout title={title} description={description} schema={schema}>
  <section class="mx-auto max-w-2xl px-4 py-8">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-brand-700">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      All games
    </a>

    <div class="mt-4 mb-1 flex items-center gap-3">
      <span class="text-3xl">{game.emoji}</span>
      <h1 class="text-2xl font-extrabold text-slate-900">{game.title}</h1>
      {game.saves && <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-bold text-emerald-700">Saves progress</span>}
    </div>
    <p class="mb-5 text-sm text-slate-500">{game.controls}</p>

    <div class="mx-auto max-w-md">
      <slot />
    </div>

    <!-- More games -->
    <div class="mt-12">
      <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-400">More games</p>
      <div class="grid grid-cols-2 gap-3">
        {others.map((g) => (
          <a href={`/play/${g.slug}`} class="flex items-center gap-3 rounded-xl border border-blue-200/70 bg-white p-3 shadow-sm hover:border-brand-400 hover:shadow-md transition">
            <span class={`grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-gradient-to-br ${g.gradient} text-xl`}>{g.emoji}</span>
            <span><span class="block text-sm font-semibold text-slate-900">{g.title}</span><span class="block text-xs text-slate-400">{g.category}</span></span>
          </a>
        ))}
      </div>
      <a href="/" class="mt-3 flex items-center justify-center gap-2 rounded-xl bg-slate-900 px-4 py-3 font-bold text-white hover:bg-slate-800 transition">🎮 Browse all games</a>
    </div>
  </section>
</Layout>
