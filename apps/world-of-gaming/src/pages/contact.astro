---
import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL } from '../lib/config';
const title = 'Contact — World of Gaming';
const description = 'Get in touch with the World of Gaming team with questions, bug reports, or game ideas.';
---
<Layout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-5 py-14">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Contact us</h1>
    <p class="mt-5 text-slate-600 leading-relaxed">We'd love to hear from you. Whether you've found a bug, have an idea for a new game, or just want to say hello, your feedback helps make World of Gaming better.</p>

    <div class="mt-8 rounded-2xl border border-blue-200 bg-white p-6 shadow-sm">
      <h2 class="font-bold text-slate-900">Email</h2>
      <p class="mt-1.5 text-slate-500">For questions, bug reports, and game suggestions:</p>
      <a href={`mailto:${CONTACT_EMAIL}`} class="mt-1 inline-block text-lg font-semibold text-brand-600 hover:text-brand-700">{CONTACT_EMAIL}</a>
      <p class="mt-4 text-sm text-slate-500">We read every message and aim to reply within a few days.</p>
    </div>

    <h2 class="mt-10 text-2xl font-bold text-slate-900">Reporting a problem with a game</h2>
    <p class="mt-4 text-slate-600 leading-relaxed">If a game isn't working right, email us and tell us which game, what device and browser you're using, and what happened. The more detail you give, the faster we can fix it.</p>
  </article>
</Layout>
