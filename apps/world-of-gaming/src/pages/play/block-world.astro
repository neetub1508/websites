---
import PlayShell from '../../components/PlayShell.astro';
---
<PlayShell slug="block-world">
  <p id="bw-saved" class="mb-2 text-center text-xs font-semibold text-emerald-600">Saved ✓</p>

  <div class="overflow-hidden rounded-2xl border border-blue-200 shadow-md">
    <canvas id="bw-world" width="360" height="300" class="block w-full" style="touch-action:none"></canvas>
  </div>

  <div id="bw-palette" class="mt-3 grid grid-cols-5 gap-2"></div>
  <div class="mt-2 flex gap-2">
    <button id="bw-erase" class="flex-1 rounded-lg bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">🧽 Erase</button>
    <button id="bw-clear" class="flex-1 rounded-lg bg-rose-100 px-3 py-2 text-sm font-semibold text-rose-600 hover:bg-rose-200">🗑️ New world</button>
  </div>
</PlayShell>

<script is:inline>
(function () {
  const cv = document.getElementById('bw-world'), ctx = cv.getContext('2d');
  const COLS = 24, ROWS = 20, S = cv.width / COLS;
  const BLOCKS = [
    { n: 'Grass', c: '#57a639', top: '#76c64f' },
    { n: 'Dirt',  c: '#7a4f2a' },
    { n: 'Stone', c: '#8d8d8d' },
    { n: 'Wood',  c: '#9c6b34' },
    { n: 'Leaves',c: '#3f9b46' },
    { n: 'Sand',  c: '#e3cd86' },
    { n: 'Water', c: '#2f7fd1' },
    { n: 'Brick', c: '#b24a39' },
    { n: 'Glass', c: '#a9d8e6' },
    { n: 'Coal',  c: '#2f2f33' },
  ];
  const KEY = 'bw_world_v1';
  let world, selected = 0, erase = false, drawing = false, lastCell = null, saveTimer = null;
  const UNSEL = 'border-slate-200 bg-slate-100', SEL = 'border-brand-400 bg-brand-500/15';

  function blank() { return Array.from({ length: ROWS }, () => Array.from({ length: COLS }, () => -1)); }
  function seedGround(w) { for (let c = 0; c < COLS; c++) { w[ROWS - 1][c] = 1; w[ROWS - 2][c] = 1; w[ROWS - 3][c] = 0; } return w; }
  function load() {
    try { const s = localStorage.getItem(KEY); if (s) { const w = JSON.parse(s); if (Array.isArray(w) && w.length === ROWS) return w; } } catch (e) {}
    return seedGround(blank());
  }
  function save() { localStorage.setItem(KEY, JSON.stringify(world)); flash(); }
  function flash() { const el = document.getElementById('bw-saved'); el.style.opacity = '1'; clearTimeout(flash._t); flash._t = setTimeout(() => (el.style.opacity = '.4'), 900); }
  function scheduleSave() { clearTimeout(saveTimer); saveTimer = setTimeout(save, 250); }

  function draw() {
    const g = ctx.createLinearGradient(0, 0, 0, cv.height); g.addColorStop(0, '#7fc7ff'); g.addColorStop(1, '#cdeafe');
    ctx.fillStyle = g; ctx.fillRect(0, 0, cv.width, cv.height);
    ctx.strokeStyle = 'rgba(0,0,0,.05)';
    for (let i = 0; i <= COLS; i++) { ctx.beginPath(); ctx.moveTo(i * S, 0); ctx.lineTo(i * S, ROWS * S); ctx.stroke(); }
    for (let i = 0; i <= ROWS; i++) { ctx.beginPath(); ctx.moveTo(0, i * S); ctx.lineTo(COLS * S, i * S); ctx.stroke(); }
    for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
      const b = world[r][c]; if (b < 0) continue;
      const x = c * S, y = r * S, bl = BLOCKS[b];
      ctx.fillStyle = bl.c; ctx.fillRect(x, y, S, S);
      if (bl.top) { ctx.fillStyle = bl.top; ctx.fillRect(x, y, S, S * 0.32); }
      ctx.fillStyle = 'rgba(255,255,255,.18)'; ctx.fillRect(x, y, S, 1.5); ctx.fillRect(x, y, 1.5, S);
      ctx.fillStyle = 'rgba(0,0,0,.18)'; ctx.fillRect(x, y + S - 1.5, S, 1.5); ctx.fillRect(x + S - 1.5, y, 1.5, S);
    }
  }

  function buildPalette() {
    document.getElementById('bw-palette').innerHTML = BLOCKS.map((b, i) =>
      `<button data-i="${i}" class="pal flex flex-col items-center gap-1 rounded-lg border p-1 text-[10px] text-slate-600 ${i === 0 ? SEL : UNSEL}">
         <span class="h-7 w-7 rounded" style="background:${b.c}"></span>${b.n}</button>`).join('');
    document.querySelectorAll('.pal').forEach((btn) => btn.onclick = () => {
      selected = +btn.dataset.i; erase = false;
      document.getElementById('bw-erase').classList.remove('ring-2', 'ring-brand-400');
      document.querySelectorAll('.pal').forEach((b) => { b.classList.remove('border-brand-400', 'bg-brand-500/15'); b.classList.add('border-slate-200', 'bg-slate-100'); });
      btn.classList.add('border-brand-400', 'bg-brand-500/15'); btn.classList.remove('border-slate-200', 'bg-slate-100');
    });
  }

  function cellAt(e) {
    const r = cv.getBoundingClientRect();
    const px = (e.clientX - r.left) * (cv.width / r.width), py = (e.clientY - r.top) * (cv.height / r.height);
    return { c: Math.floor(px / S), r: Math.floor(py / S) };
  }
  function paint(e) {
    const { c, r } = cellAt(e); if (c < 0 || r < 0 || c >= COLS || r >= ROWS) return;
    const k = r + ',' + c; if (k === lastCell) return; lastCell = k;
    world[r][c] = erase ? -1 : selected; draw(); scheduleSave();
  }
  cv.addEventListener('pointerdown', (e) => { drawing = true; lastCell = null; paint(e); e.preventDefault(); });
  cv.addEventListener('pointermove', (e) => { if (drawing) paint(e); });
  addEventListener('pointerup', () => { if (drawing) { drawing = false; save(); } });

  document.getElementById('bw-erase').onclick = function () {
    erase = true; this.classList.add('ring-2', 'ring-brand-400');
    document.querySelectorAll('.pal').forEach((b) => { b.classList.remove('border-brand-400', 'bg-brand-500/15'); b.classList.add('border-slate-200', 'bg-slate-100'); });
  };
  document.getElementById('bw-clear').onclick = () => { if (confirm('Clear your whole world? This cannot be undone.')) { world = seedGround(blank()); draw(); save(); } };

  world = load(); buildPalette(); draw(); flash();
})();
</script>
