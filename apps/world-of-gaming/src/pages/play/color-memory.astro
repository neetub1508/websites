---
import PlayShell from '../../components/PlayShell.astro';
---
<PlayShell slug="color-memory">
  <div class="mb-3 flex items-center justify-between">
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Level: <span id="cm-level" class="font-bold text-slate-900">0</span></div>
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Best: <span id="cm-best" class="font-bold text-brand-600">0</span></div>
  </div>

  <div id="cm-pads" class="grid grid-cols-2 gap-3">
    <button class="pad aspect-square rounded-2xl" data-i="0" style="background:#22c55e"></button>
    <button class="pad aspect-square rounded-2xl" data-i="1" style="background:#ef4444"></button>
    <button class="pad aspect-square rounded-2xl" data-i="2" style="background:#eab308"></button>
    <button class="pad aspect-square rounded-2xl" data-i="3" style="background:#3b82f6"></button>
  </div>

  <p id="cm-status" class="mt-4 text-center text-base font-bold text-slate-700">Press Start and watch the colors</p>
  <button id="cm-start" class="mt-3 w-full rounded-xl bg-brand-500 px-4 py-3 font-bold text-white hover:bg-brand-600">▶ Start</button>
</PlayShell>

<style is:global>
  .pad { opacity: .5; transition: opacity .1s ease, transform .1s ease; cursor: pointer; }
  .pad.on { opacity: 1; transform: scale(1.04); box-shadow: 0 8px 24px -4px rgba(0,0,0,.35); }
</style>

<script is:inline>
(function () {
  const pads = Array.from(document.querySelectorAll('.pad'));
  const levelEl = document.getElementById('cm-level'), bestEl = document.getElementById('cm-best'), statusEl = document.getElementById('cm-status'), startBtn = document.getElementById('cm-start');
  const KEY = 'simon_best';
  let best = +(localStorage.getItem(KEY) || 0); bestEl.textContent = best;
  let seq = [], expect = 0, accepting = false;

  function setStatus(t, cls) { statusEl.textContent = t; statusEl.className = 'mt-4 text-center text-base font-bold ' + (cls || 'text-slate-700'); }
  function flashOn(i) { pads[i].classList.add('on'); }
  function flashOff(i) { pads[i].classList.remove('on'); }

  function start() { seq = []; startBtn.textContent = '↻ Restart'; addStep(); }
  function addStep() {
    seq.push((Math.random() * 4) | 0); levelEl.textContent = seq.length; accepting = false; setStatus('Watch…', 'text-slate-500');
    setTimeout(() => playFrom(0), 550);
  }
  function playFrom(k) {
    if (k >= seq.length) { accepting = true; expect = 0; setStatus('Your turn — repeat it', 'text-brand-700'); return; }
    flashOn(seq[k]);
    setTimeout(() => { flashOff(seq[k]); setTimeout(() => playFrom(k + 1), 180); }, 430);
  }

  function press(i) {
    if (!accepting) return;
    flashOn(i); setTimeout(() => flashOff(i), 160);
    if (i === seq[expect]) {
      expect++;
      if (expect === seq.length) {
        accepting = false;
        if (seq.length > best) { best = seq.length; localStorage.setItem(KEY, best); bestEl.textContent = best; }
        setStatus('Nice! Next round…', 'text-emerald-600');
        setTimeout(addStep, 700);
      }
    } else {
      accepting = false;
      setStatus('❌ Wrong! Reached level ' + (seq.length - 1), 'text-rose-600');
      startBtn.textContent = '▶ Play again';
    }
  }

  pads.forEach((p) => p.addEventListener('click', () => press(+p.dataset.i)));
  startBtn.onclick = start;
})();
</script>
