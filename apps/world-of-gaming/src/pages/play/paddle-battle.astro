---
import PlayShell from '../../components/PlayShell.astro';
---
<PlayShell slug="paddle-battle">
  <div class="mb-3 flex items-center justify-between">
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">You <span id="b-you" class="font-bold text-slate-900">0</span> · CPU <span id="b-cpu" class="font-bold text-slate-900">0</span></div>
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Wins: <span id="b-wins" class="font-bold text-brand-600">0</span></div>
  </div>

  <div class="relative overflow-hidden rounded-2xl border border-blue-200 shadow-md">
    <canvas id="b-game" width="360" height="460" class="block w-full" style="touch-action:none"></canvas>
    <div id="b-overlay" class="absolute inset-0 grid place-items-center bg-slate-900/60 backdrop-blur-sm">
      <div class="text-center">
        <p id="b-msg" class="mb-4 text-xl font-bold text-white">First to 7 wins</p>
        <button id="b-start" class="rounded-xl bg-brand-500 px-6 py-3 font-bold text-white shadow-lg hover:bg-brand-600">▶ Start</button>
      </div>
    </div>
  </div>
  <p class="mt-2 text-center text-xs text-slate-500">Drag up/down on the board, or use ↑ ↓ keys.</p>
</PlayShell>

<script is:inline>
(function () {
  const cv = document.getElementById('b-game'), ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
  const youEl = document.getElementById('b-you'), cpuEl = document.getElementById('b-cpu'), winsEl = document.getElementById('b-wins');
  const overlay = document.getElementById('b-overlay'), msg = document.getElementById('b-msg'), startBtn = document.getElementById('b-start');
  const KEY = 'pong_wins';
  let wins = +(localStorage.getItem(KEY) || 0); winsEl.textContent = wins;
  const PW = 12, PH = 70, MARGIN = 16, TARGET = 7;
  let you, cpu, ball, sYou, sCpu, running, raf, keyUp = false, keyDn = false;

  function reset() { you = H / 2 - PH / 2; cpu = H / 2 - PH / 2; sYou = 0; sCpu = 0; youEl.textContent = 0; cpuEl.textContent = 0; running = true; serve(Math.random() < 0.5 ? 1 : -1); }
  function serve(dir) { ball = { x: W / 2, y: H / 2, vx: dir * 4, vy: (Math.random() * 4 - 2), sp: 4.2 }; }

  function loop() {
    // move paddles
    if (keyUp) you -= 6; if (keyDn) you += 6;
    you = Math.max(0, Math.min(H - PH, you));
    // CPU AI (beatable: capped speed, slight lag)
    const cpuMid = cpu + PH / 2, target = ball.y;
    if (cpuMid < target - 6) cpu += 3.3; else if (cpuMid > target + 6) cpu -= 3.3;
    cpu = Math.max(0, Math.min(H - PH, cpu));

    ball.x += ball.vx; ball.y += ball.vy;
    if (ball.y < 6) { ball.y = 6; ball.vy = -ball.vy; } if (ball.y > H - 6) { ball.y = H - 6; ball.vy = -ball.vy; }

    // player paddle (left)
    if (ball.x - 6 < MARGIN + PW && ball.x > MARGIN && ball.vx < 0 && ball.y > you && ball.y < you + PH) { bounce(you); ball.x = MARGIN + PW + 6; }
    // cpu paddle (right)
    if (ball.x + 6 > W - MARGIN - PW && ball.x < W - MARGIN && ball.vx > 0 && ball.y > cpu && ball.y < cpu + PH) { bounce(cpu); ball.x = W - MARGIN - PW - 6; }

    if (ball.x < 0) { sCpu++; cpuEl.textContent = sCpu; point(-1); }
    else if (ball.x > W) { sYou++; youEl.textContent = sYou; point(1); }

    draw();
    if (running) raf = requestAnimationFrame(loop);
  }
  function bounce(py) { const rel = ((ball.y - (py + PH / 2)) / (PH / 2)); ball.sp = Math.min(9, ball.sp + 0.4); const ang = rel * (Math.PI / 3.2); ball.vx = (ball.vx < 0 ? 1 : -1) * ball.sp * Math.cos(ang); ball.vy = ball.sp * Math.sin(ang); }
  function point(scorer) {
    if (sYou >= TARGET || sCpu >= TARGET) {
      running = false; cancelAnimationFrame(raf);
      const won = sYou > sCpu;
      if (won) { wins++; localStorage.setItem(KEY, wins); winsEl.textContent = wins; }
      msg.textContent = won ? '🏆 You win the match!' : '😬 CPU wins the match'; startBtn.textContent = '↻ Play again'; overlay.classList.remove('hidden');
      return;
    }
    serve(scorer > 0 ? -1 : 1);
  }

  function draw() {
    ctx.fillStyle = '#0a1733'; ctx.fillRect(0, 0, W, H);
    ctx.strokeStyle = 'rgba(255,255,255,.2)'; ctx.setLineDash([6, 10]); ctx.beginPath(); ctx.moveTo(W / 2, 0); ctx.lineTo(W / 2, H); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle = '#38bdf8'; ctx.beginPath(); ctx.roundRect(MARGIN, you, PW, PH, 5); ctx.fill();
    ctx.fillStyle = '#f87171'; ctx.beginPath(); ctx.roundRect(W - MARGIN - PW, cpu, PW, PH, 5); ctx.fill();
    ctx.fillStyle = '#fff'; ctx.shadowColor = 'rgba(255,255,255,.7)'; ctx.shadowBlur = 10; ctx.beginPath(); ctx.arc(ball.x, ball.y, 6, 0, 7); ctx.fill(); ctx.shadowBlur = 0;
  }

  function start() { overlay.classList.add('hidden'); reset(); loop(); }
  startBtn.onclick = start;
  addEventListener('keydown', (e) => { if (e.key === 'ArrowUp' || e.key === 'w') { e.preventDefault(); keyUp = true; } if (e.key === 'ArrowDown' || e.key === 's') { e.preventDefault(); keyDn = true; } });
  addEventListener('keyup', (e) => { if (e.key === 'ArrowUp' || e.key === 'w') keyUp = false; if (e.key === 'ArrowDown' || e.key === 's') keyDn = false; });
  function moveTo(clientY) { const r = cv.getBoundingClientRect(); you = Math.max(0, Math.min(H - PH, (clientY - r.top) * (H / r.height) - PH / 2)); }
  cv.addEventListener('pointermove', (e) => { if (running) moveTo(e.clientY); });
  cv.addEventListener('touchmove', (e) => { if (running) { moveTo(e.touches[0].clientY); e.preventDefault(); } }, { passive: false });
})();
</script>
