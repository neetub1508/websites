---
import PlayShell from '../../components/PlayShell.astro';
---
<PlayShell slug="tower-obby">
  <div class="mb-3 flex items-center justify-between">
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Level: <span id="to-level" class="font-bold text-slate-900">1</span></div>
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Falls: <span id="to-falls" class="font-bold text-slate-900">0</span></div>
    <button id="to-reset" class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-200">Restart level</button>
  </div>

  <div class="overflow-hidden rounded-2xl border border-blue-200 shadow-md">
    <canvas id="to-game" width="360" height="460" class="block w-full" style="touch-action:none"></canvas>
  </div>

  <div class="mt-3 grid grid-cols-3 gap-2 sm:hidden">
    <button id="to-left" class="rounded-xl bg-slate-200 py-4 text-2xl font-bold text-slate-800 select-none">←</button>
    <button id="to-jump" class="rounded-xl bg-brand-500 py-4 text-lg font-bold text-white select-none">JUMP</button>
    <button id="to-right" class="rounded-xl bg-slate-200 py-4 text-2xl font-bold text-slate-800 select-none">→</button>
  </div>
  <p class="mt-2 hidden text-center text-xs text-slate-500 sm:block">Desktop: ← → to move, Space / ↑ to jump.</p>
</PlayShell>

<script is:inline>
(function () {
  const cv = document.getElementById('to-game'), ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
  const levelEl = document.getElementById('to-level'), fallsEl = document.getElementById('to-falls');
  const KEY = 'to_level_v1';
  const GRAV = 0.6, MOVE = 3.4, JUMP = -12.2;
  const G = H - 24;
  const LEVELS = [
    { start: { x: 30, y: G - 30 }, flag: { x: 300, y: 90 },
      plats: [{ x: 0, y: G, w: W }, { x: 70, y: G - 70, w: 70 }, { x: 180, y: G - 130, w: 70 }, { x: 80, y: G - 190, w: 70 }, { x: 200, y: G - 250, w: 70 }, { x: 280, y: G - 320, w: 70 }] },
    { start: { x: 30, y: G - 30 }, flag: { x: 40, y: 90 },
      plats: [{ x: 0, y: G, w: W }, { x: 230, y: G - 60, w: 60 }, { x: 120, y: G - 120, w: 60 }, { x: 250, y: G - 180, w: 55 }, { x: 130, y: G - 240, w: 55 }, { x: 10, y: G - 300, w: 70 }] },
    { start: { x: 170, y: G - 30 }, flag: { x: 170, y: 70 },
      plats: [{ x: 0, y: G, w: W }, { x: 40, y: G - 70, w: 50 }, { x: 270, y: G - 70, w: 50 }, { x: 60, y: G - 140, w: 50 }, { x: 250, y: G - 140, w: 50 }, { x: 90, y: G - 210, w: 50 }, { x: 220, y: G - 210, w: 50 }, { x: 140, y: G - 280, w: 80 }] },
    { start: { x: 20, y: G - 30 }, flag: { x: 320, y: 70 },
      plats: [{ x: 0, y: G, w: W }, { x: 90, y: G - 60, w: 45 }, { x: 200, y: G - 110, w: 45 }, { x: 60, y: G - 170, w: 40 }, { x: 180, y: G - 220, w: 40 }, { x: 280, y: G - 270, w: 45 }, { x: 160, y: G - 310, w: 40 }, { x: 300, y: G - 300, w: 55 }] },
    { start: { x: 16, y: G - 30 }, flag: { x: 175, y: 70 },
      plats: [{ x: 0, y: G, w: W }, { x: 250, y: G - 60, w: 50 }, { x: 120, y: G - 115, w: 50 }, { x: 260, y: G - 170, w: 45 }, { x: 130, y: G - 225, w: 45 }, { x: 250, y: G - 280, w: 45 }, { x: 140, y: G - 330, w: 90 }] },
    { start: { x: 175, y: G - 30 }, flag: { x: 30, y: 70 },
      plats: [{ x: 0, y: G, w: W }, { x: 150, y: G - 65, w: 55 }, { x: 40, y: G - 120, w: 45 }, { x: 260, y: G - 120, w: 45 }, { x: 150, y: G - 175, w: 45 }, { x: 40, y: G - 235, w: 45 }, { x: 240, y: G - 235, w: 45 }, { x: 20, y: G - 300, w: 70 }] },
    { start: { x: 16, y: G - 30 }, flag: { x: 320, y: 70 },
      plats: [{ x: 0, y: G, w: 90 }, { x: 130, y: G - 55, w: 40 }, { x: 230, y: G - 100, w: 40 }, { x: 120, y: G - 150, w: 38 }, { x: 20, y: G - 200, w: 38 }, { x: 150, y: G - 250, w: 38 }, { x: 280, y: G - 220, w: 40 }, { x: 290, y: G - 300, w: 60 }] },
    { start: { x: 175, y: G - 30 }, flag: { x: 175, y: 60 },
      plats: [{ x: 0, y: G, w: W }, { x: 30, y: G - 65, w: 40 }, { x: 290, y: G - 65, w: 40 }, { x: 90, y: G - 125, w: 38 }, { x: 232, y: G - 125, w: 38 }, { x: 30, y: G - 190, w: 38 }, { x: 290, y: G - 190, w: 38 }, { x: 120, y: G - 250, w: 38 }, { x: 210, y: G - 250, w: 38 }, { x: 150, y: G - 315, w: 70 }] },
  ];
  let cur = 0, falls = 0, p, keys = { left: false, right: false }, alive = true;

  function loadLevel(i) {
    cur = Math.min(i, LEVELS.length - 1);
    const L = LEVELS[cur];
    p = { x: L.start.x, y: L.start.y, w: 22, h: 26, vx: 0, vy: 0, onGround: false };
    levelEl.textContent = (cur + 1) + ' / ' + LEVELS.length;
  }
  function saveProgress() { localStorage.setItem(KEY, String(cur)); }

  function draw() {
    const L = LEVELS[cur];
    const g = ctx.createLinearGradient(0, 0, 0, H); g.addColorStop(0, '#0a1733'); g.addColorStop(1, '#16305f');
    ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);
    for (const pl of L.plats) { ctx.fillStyle = '#22c55e'; ctx.fillRect(pl.x, pl.y, pl.w, 12); ctx.fillStyle = 'rgba(255,255,255,.25)'; ctx.fillRect(pl.x, pl.y, pl.w, 3); }
    ctx.font = '26px serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText('🚩', L.flag.x, L.flag.y);
    ctx.fillStyle = '#ef4444'; ctx.beginPath(); ctx.roundRect(p.x, p.y, p.w, p.h, 5); ctx.fill();
    ctx.fillStyle = '#fff'; ctx.fillRect(p.x + 4, p.y + 7, 4, 4); ctx.fillRect(p.x + p.w - 8, p.y + 7, 4, 4);
  }

  function step() {
    const L = LEVELS[cur];
    p.vx = (keys.left ? -MOVE : 0) + (keys.right ? MOVE : 0);
    p.x += p.vx; if (p.x < 0) p.x = 0; if (p.x + p.w > W) p.x = W - p.w;
    p.vy += GRAV; p.y += p.vy; p.onGround = false;
    for (const pl of L.plats) {
      if (p.x + p.w > pl.x && p.x < pl.x + pl.w && p.vy >= 0 && p.y + p.h >= pl.y && p.y + p.h <= pl.y + 18) { p.y = pl.y - p.h; p.vy = 0; p.onGround = true; }
    }
    if (p.y > H + 40) { falls++; fallsEl.textContent = falls; loadLevel(cur); }
    if (Math.abs((p.x + p.w / 2) - L.flag.x) < 26 && Math.abs((p.y + p.h / 2) - L.flag.y) < 30) {
      if (cur + 1 < LEVELS.length) { loadLevel(cur + 1); saveProgress(); } else { return winAll(); }
    }
    draw();
    if (alive) requestAnimationFrame(step);
  }

  function winAll() {
    alive = false;
    ctx.fillStyle = 'rgba(0,0,0,.7)'; ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = '#fff'; ctx.font = 'bold 22px Outfit,sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('🎉 You beat every level!', W / 2, H / 2 - 10);
    ctx.font = '14px Outfit,sans-serif'; ctx.fillText('Tap Restart level to play again.', W / 2, H / 2 + 20);
    localStorage.removeItem(KEY); cur = 0;
  }
  function jump() { if (p && p.onGround) { p.vy = JUMP; p.onGround = false; } }

  addEventListener('keydown', (e) => { if (e.key === 'ArrowLeft' || e.key === 'a') keys.left = true; if (e.key === 'ArrowRight' || e.key === 'd') keys.right = true; if (e.code === 'Space' || e.key === 'ArrowUp' || e.key === 'w') { e.preventDefault(); jump(); } });
  addEventListener('keyup', (e) => { if (e.key === 'ArrowLeft' || e.key === 'a') keys.left = false; if (e.key === 'ArrowRight' || e.key === 'd') keys.right = false; });
  function hold(id, on, off) { const el = document.getElementById(id); el.addEventListener('pointerdown', (e) => { e.preventDefault(); on(); }); el.addEventListener('pointerup', off); el.addEventListener('pointerleave', off); el.addEventListener('pointercancel', off); }
  hold('to-left', () => keys.left = true, () => keys.left = false);
  hold('to-right', () => keys.right = true, () => keys.right = false);
  document.getElementById('to-jump').addEventListener('pointerdown', (e) => { e.preventDefault(); jump(); });
  document.getElementById('to-reset').onclick = () => { alive = true; loadLevel(cur); };

  const saved = parseInt(localStorage.getItem(KEY) || '0', 10);
  loadLevel(isNaN(saved) ? 0 : saved);
  step();
})();
</script>
