---
import PlayShell from '../../components/PlayShell.astro';
---
<PlayShell slug="brick-breaker">
  <div class="mb-3 flex items-center justify-between">
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Score: <span id="b-score" class="font-bold text-slate-900">0</span></div>
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Lives: <span id="b-lives" class="font-bold text-slate-900">3</span></div>
    <div class="rounded-lg bg-slate-100 px-3 py-1.5 text-sm text-slate-600">Best: <span id="b-best" class="font-bold text-brand-600">0</span></div>
  </div>

  <div class="relative overflow-hidden rounded-2xl border border-blue-200 shadow-md">
    <canvas id="b-game" width="360" height="440" class="block w-full" style="touch-action:none"></canvas>
    <div id="b-overlay" class="absolute inset-0 grid place-items-center bg-slate-900/70 backdrop-blur-sm">
      <div class="text-center">
        <p id="b-msg" class="mb-4 text-xl font-bold text-white">Tap to start</p>
        <button id="b-start" class="rounded-xl bg-brand-500 px-6 py-3 font-bold text-white shadow-lg hover:bg-brand-600">▶ Start</button>
      </div>
    </div>
  </div>
  <p class="mt-2 text-center text-xs text-slate-500">Move the paddle with your finger or ← →. Tap / Space to launch.</p>
</PlayShell>

<script is:inline>
(function () {
  const cv = document.getElementById('b-game'), ctx = cv.getContext('2d'), W = cv.width, H = cv.height;
  const scoreEl = document.getElementById('b-score'), livesEl = document.getElementById('b-lives'), bestEl = document.getElementById('b-best');
  const overlay = document.getElementById('b-overlay'), msg = document.getElementById('b-msg'), startBtn = document.getElementById('b-start');
  const KEY = 'bb_best';
  let best = +(localStorage.getItem(KEY) || 0); bestEl.textContent = best;

  const ROWS = 5, COLS = 9, MARGIN = 16, GAP = 5, TOP = 46, BRICK_H = 16;
  const BRICK_W = (W - 2 * MARGIN - (COLS - 1) * GAP) / COLS;
  const ROW_COLORS = ['#ef4444', '#f97316', '#eab308', '#22c55e', '#0ea5e9'];

  let paddle, ball, bricks, lives, score, level, launched, running, keys = { l: false, r: false };

  function speed() { return 3.5 + (level - 1) * 0.5; }
  function makeBricks() {
    bricks = [];
    for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++)
      bricks.push({ x: MARGIN + c * (BRICK_W + GAP), y: TOP + r * (BRICK_H + GAP), w: BRICK_W, h: BRICK_H, alive: true, color: ROW_COLORS[r] });
  }
  function resetBall() { launched = false; ball = { x: paddle.x + paddle.w / 2, y: paddle.y - 7, r: 6, vx: 0, vy: 0 }; }
  function newGame() { paddle = { x: W / 2 - 35, y: H - 26, w: 70, h: 12 }; lives = 3; score = 0; level = 1; resetBall(); makeBricks(); running = true; scoreEl.textContent = 0; livesEl.textContent = 3; }
  function launch() { if (launched) return; launched = true; const sp = speed(); const ang = (Math.random() * 0.5 - 0.25); ball.vx = sp * Math.sin(ang); ball.vy = -sp * Math.cos(ang); }

  function loop() { if (!running) return; update(); draw(); requestAnimationFrame(loop); }

  function update() {
    if (keys.l) paddle.x -= 6; if (keys.r) paddle.x += 6;
    paddle.x = Math.max(0, Math.min(W - paddle.w, paddle.x));
    if (!launched) { ball.x = paddle.x + paddle.w / 2; ball.y = paddle.y - 7; return; }

    ball.x += ball.vx; ball.y += ball.vy;
    if (ball.x < ball.r) { ball.x = ball.r; ball.vx = -ball.vx; }
    if (ball.x > W - ball.r) { ball.x = W - ball.r; ball.vx = -ball.vx; }
    if (ball.y < ball.r) { ball.y = ball.r; ball.vy = -ball.vy; }

    // paddle
    if (ball.vy > 0 && ball.y + ball.r >= paddle.y && ball.y < paddle.y + paddle.h && ball.x > paddle.x && ball.x < paddle.x + paddle.w) {
      const rel = Math.max(-1, Math.min(1, (ball.x - (paddle.x + paddle.w / 2)) / (paddle.w / 2)));
      const sp = speed(), ang = rel * (Math.PI / 3);
      ball.vx = sp * Math.sin(ang); ball.vy = -Math.abs(sp * Math.cos(ang)); ball.y = paddle.y - ball.r;
    }

    // bricks
    for (const b of bricks) {
      if (!b.alive) continue;
      if (ball.x + ball.r > b.x && ball.x - ball.r < b.x + b.w && ball.y + ball.r > b.y && ball.y - ball.r < b.y + b.h) {
        b.alive = false; score += 10; scoreEl.textContent = score;
        if (score > best) { best = score; localStorage.setItem(KEY, best); bestEl.textContent = best; }
        const ox = Math.min(ball.x + ball.r - b.x, b.x + b.w - (ball.x - ball.r));
        const oy = Math.min(ball.y + ball.r - b.y, b.y + b.h - (ball.y - ball.r));
        if (ox < oy) ball.vx = -ball.vx; else ball.vy = -ball.vy;
        break;
      }
    }
    if (bricks.every((b) => !b.alive)) { level++; makeBricks(); resetBall(); }

    if (ball.y - ball.r > H) {
      lives--; livesEl.textContent = lives;
      if (lives <= 0) return gameOver();
      resetBall();
    }
  }

  function draw() {
    const g = ctx.createLinearGradient(0, 0, 0, H); g.addColorStop(0, '#0a1733'); g.addColorStop(1, '#16305f');
    ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);
    for (const b of bricks) { if (!b.alive) continue; ctx.fillStyle = b.color; ctx.beginPath(); ctx.roundRect(b.x, b.y, b.w, b.h, 3); ctx.fill(); ctx.fillStyle = 'rgba(255,255,255,.25)'; ctx.fillRect(b.x, b.y, b.w, 3); }
    ctx.fillStyle = '#e2e8f0'; ctx.beginPath(); ctx.roundRect(paddle.x, paddle.y, paddle.w, paddle.h, 6); ctx.fill();
    ctx.fillStyle = '#38bdf8'; ctx.shadowColor = 'rgba(56,189,248,.8)'; ctx.shadowBlur = 12; ctx.beginPath(); ctx.arc(ball.x, ball.y, ball.r, 0, 7); ctx.fill(); ctx.shadowBlur = 0;
    if (!launched) { ctx.fillStyle = 'rgba(255,255,255,.7)'; ctx.font = '12px Outfit,sans-serif'; ctx.textAlign = 'center'; ctx.fillText('Tap or press Space to launch', W / 2, H - 50); }
  }

  function gameOver() { running = false; msg.textContent = 'Game Over · Score ' + score; startBtn.textContent = '↻ Play again'; overlay.classList.remove('hidden'); }
  function start() { overlay.classList.add('hidden'); newGame(); loop(); }
  startBtn.onclick = start;

  addEventListener('keydown', (e) => { if (e.key === 'ArrowLeft' || e.key === 'a') keys.l = true; if (e.key === 'ArrowRight' || e.key === 'd') keys.r = true; if (e.code === 'Space') { e.preventDefault(); launch(); } });
  addEventListener('keyup', (e) => { if (e.key === 'ArrowLeft' || e.key === 'a') keys.l = false; if (e.key === 'ArrowRight' || e.key === 'd') keys.r = false; });
  function moveTo(clientX) { const r = cv.getBoundingClientRect(); paddle.x = Math.max(0, Math.min(W - paddle.w, (clientX - r.left) * (W / r.width) - paddle.w / 2)); }
  cv.addEventListener('pointermove', (e) => { if (running) moveTo(e.clientX); });
  cv.addEventListener('pointerdown', (e) => { if (running) { moveTo(e.clientX); launch(); } });
})();
</script>
