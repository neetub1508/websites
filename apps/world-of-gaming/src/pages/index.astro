---
import Layout from '../layouts/Layout.astro';
import { GAMES } from '../lib/games';
import { SITE_URL, SITE_NAME } from '../lib/config';

const title = 'World of Gaming — Play Free Online Games | No Download, Instant Play';
const description =
  'World of Gaming is a free online games site. Play Block World, Tower Obby, 2048, Neon Snake, Brick Breaker and Candy Match right in your browser — no download, no sign-up. Works on mobile and desktop.';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  description,
};
const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free games on World of Gaming',
  itemListElement: GAMES.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: g.title,
    url: `${SITE_URL}/play/${g.slug}`,
  })),
};
---

<Layout title={title} description={description} schema={[websiteSchema, listSchema]}>
  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden border-b border-blue-200/70">
    <div class="absolute -z-10 top-[-20%] left-[10%] w-[32rem] h-[32rem] rounded-full bg-brand-300/40 blur-3xl"></div>
    <div class="absolute -z-10 top-[-10%] right-[5%] w-[28rem] h-[28rem] rounded-full bg-indigo-300/30 blur-3xl"></div>

    <div class="mx-auto max-w-6xl px-5 py-16 sm:py-20 text-center relative">
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-3.5 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-brand-700 ring-1 ring-brand-300/60 shadow-sm">
        <span class="h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_8px_2px_rgba(16,185,129,.6)]"></span> Free to play arcade
      </span>
      <h1 class="mt-6 text-5xl sm:text-6xl font-extrabold tracking-tight text-slate-900 glow text-balance">
        PLAY FREE GAMES
      </h1>
      <p class="mt-4 text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">
        Build a world, climb a tower, smash some bricks. Original browser games that load instantly on World of Gaming — no download, no sign-up.
      </p>

      <div class="mt-7 flex flex-wrap items-center justify-center gap-2.5">
        <span class="pill">🎮 {GAMES.length} games</span>
        <span class="pill">⚡ Instant play</span>
        <span class="pill">💾 Saves progress</span>
        <span class="pill">📱 Mobile &amp; desktop</span>
      </div>

      <a href="#games" class="mt-9 inline-flex items-center gap-2 rounded-2xl bg-brand-500 px-7 py-3.5 text-base font-extrabold text-white shadow-[0_10px_30px_-6px_rgba(14,165,233,.7)] hover:bg-brand-600 transition">
        ▶ START PLAYING
      </a>
    </div>
  </section>

  <!-- ===== GAMES GRID ===== -->
  <section id="games" class="mx-auto max-w-6xl px-5 pt-12">
    <div class="mb-6 flex items-end justify-between">
      <h2 class="flex items-center gap-2 text-2xl font-extrabold text-slate-900"><span>🎮</span> All Games</h2>
      <span class="text-xs font-semibold uppercase tracking-widest text-slate-400">{GAMES.length} free games</span>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {GAMES.map((g) => (
        <a href={`/play/${g.slug}`} class="game-tile group block overflow-hidden rounded-3xl border border-blue-200/70 bg-white shadow-sm">
          <div class={`relative grid aspect-[16/10] place-items-center bg-gradient-to-br ${g.gradient}`}>
            <span class="absolute inset-0 opacity-20" style="background-image:radial-gradient(circle at 30% 20%, rgba(255,255,255,.6), transparent 45%)"></span>
            <span class="text-7xl drop-shadow-[0_6px_14px_rgba(0,0,0,.35)]">{g.emoji}</span>
            <span class="absolute right-3 top-3 rounded-full bg-black/30 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide text-white backdrop-blur">{g.category}</span>
            {g.saves && (
              <span class="absolute left-3 top-3 rounded-full bg-emerald-500 px-2.5 py-1 text-[11px] font-bold text-white shadow-[0_0_12px_rgba(16,185,129,.6)]">💾 Saves</span>
            )}
            <span class="absolute inset-0 grid place-items-center bg-black/40 opacity-0 transition group-hover:opacity-100">
              <span class="rounded-full bg-white px-6 py-2.5 text-sm font-extrabold text-slate-900 shadow-xl">▶ PLAY NOW</span>
            </span>
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-extrabold text-slate-900">{g.title}</h3>
              <span class="rounded bg-brand-100 px-1.5 py-0.5 text-[10px] font-bold uppercase text-brand-700">Free</span>
            </div>
            <p class="mt-0.5 text-sm font-medium text-brand-600">{g.tagline}</p>
            <p class="mt-2 text-sm text-slate-500 leading-relaxed">{g.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== PERKS STRIP ===== -->
  <section class="mx-auto max-w-6xl px-5 mt-16">
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {[
        ['⚡', 'Instant play', 'Games load in seconds, right in your browser.'],
        ['📱', 'Any device', 'Touch controls on mobile, keyboard on desktop.'],
        ['💾', 'Saves progress', 'Your builds and high scores are kept for next time.'],
        ['🔓', 'No sign-up', 'No account, no cost, no personal details.'],
      ].map(([icon, t, d]) => (
        <div class="rounded-2xl border border-blue-200/70 bg-white p-4 shadow-sm">
          <div class="text-2xl">{icon}</div>
          <h3 class="mt-1.5 font-bold text-slate-900 text-sm">{t}</h3>
          <p class="mt-1 text-[13px] text-slate-500 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== SHORT ABOUT ===== -->
  <section class="mx-auto max-w-3xl px-5 mt-16 text-center">
    <h2 class="text-xl font-extrabold text-slate-900">Free online games, ready when you are</h2>
    <p class="mt-3 text-slate-500 leading-relaxed">
      World of Gaming is a free games arcade with original browser games you can play instantly — no downloads, no installs, no waiting.
      Build whatever you imagine in <a href="/play/block-world" class="text-brand-600 hover:underline">Block World</a>,
      chase a high score in <a href="/play/snake" class="text-brand-600 hover:underline">Neon Snake</a> and
      <a href="/play/2048" class="text-brand-600 hover:underline">2048</a>,
      or smash through <a href="/play/brick-breaker" class="text-brand-600 hover:underline">Brick Breaker</a>. New games added over time.
    </p>
  </section>
</Layout>

<style>
  .glow { text-shadow: 0 8px 30px rgba(14, 165, 233, 0.28); }
  .pill {
    display: inline-flex; align-items: center;
    border-radius: 9999px; border: 1px solid rgba(59, 130, 246, 0.25);
    background: #ffffff;
    padding: 0.4rem 0.85rem; font-size: 0.8rem; font-weight: 600; color: #475569;
    box-shadow: 0 1px 2px rgba(2, 6, 23, 0.04);
  }
  .game-tile { transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
  .game-tile:hover { transform: translateY(-5px); border-color: rgba(14, 165, 233, .5); box-shadow: 0 22px 50px -18px rgba(14, 165, 233, .55); }
</style>
