---
interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
const { title, description, schema } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const jsonLd = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#4f46e5" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Easy1099Tax" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased flex flex-col selection:bg-indigo-200/60">
    <header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/80 backdrop-blur-lg">
      <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 font-bold text-[17px] tracking-tight">
          <span class="grid place-items-center w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-sm shadow-violet-600/30 text-[13px] font-extrabold">
            99
          </span>
          <span>Easy<span class="text-indigo-600">1099</span>Tax</span>
        </a>
        <nav class="text-sm font-medium text-slate-600 hidden sm:flex items-center gap-7">
          <a href="/" class="hover:text-indigo-700 transition">Calculator</a>
          <a href="#how-it-works" class="hover:text-indigo-700 transition">How it works</a>
          <a href="#quarterly" class="hover:text-indigo-700 transition">Quarterly taxes</a>
          <a href="#faq" class="hover:text-indigo-700 transition">FAQ</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 mt-20">
      <div class="mx-auto max-w-6xl px-5 py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-sm">
        <div class="space-y-3">
          <div class="flex items-center gap-2 font-bold">
            <span class="grid place-items-center w-7 h-7 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600 text-white text-xs font-extrabold">99</span>
            Easy1099Tax
          </div>
          <p class="text-slate-500 leading-relaxed">Free, instant self-employment &amp; 1099 tax calculator for U.S. freelancers, gig workers, and contractors.</p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Tool</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/" class="hover:text-indigo-700">1099 tax calculator</a></li>
            <li><a href="#how-it-works" class="hover:text-indigo-700">How it works</a></li>
            <li><a href="#quarterly" class="hover:text-indigo-700">Quarterly taxes</a></li>
            <li><a href="#faq" class="hover:text-indigo-700">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Learn</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="#what-is" class="hover:text-indigo-700">What is SE tax?</a></li>
            <li><a href="#deductions" class="hover:text-indigo-700">Deductions</a></li>
            <li><a href="#how-it-works" class="hover:text-indigo-700">Worked example</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Legal</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/about" class="hover:text-indigo-700">About</a></li>
            <li><a href="/contact" class="hover:text-indigo-700">Contact</a></li>
            <li><a href="/privacy" class="hover:text-indigo-700">Privacy</a></li>
            <li><a href="/terms" class="hover:text-indigo-700">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-slate-200">
        <p class="mx-auto max-w-6xl px-5 py-5 text-xs text-slate-400">
          © {year} Easy1099Tax. Estimates for informational purposes only — not tax, legal, or financial advice. Consult a qualified tax professional and <a href="https://www.irs.gov" class="underline hover:text-indigo-600">IRS.gov</a> for your specific situation.
        </p>
      </div>
    </footer>
  </body>
</html>
