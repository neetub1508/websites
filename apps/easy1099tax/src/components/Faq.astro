---
import type { Faq } from '../lib/seo';
interface Props { faqs: Faq[] }
const { faqs } = Astro.props;
---
<div class="mt-8 divide-y divide-slate-200 border-y border-slate-200">
  {faqs.map((f) => (
    <details class="group py-4">
      <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-slate-800">
        {f.q}
        <svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-45 shrink-0 ml-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </summary>
      <p class="mt-3 text-slate-600 leading-relaxed">{f.a}</p>
    </details>
  ))}
</div>
