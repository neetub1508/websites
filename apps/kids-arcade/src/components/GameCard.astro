---
import type { Game } from '../lib/games';
interface Props {
  game: Game;
}
const { game } = Astro.props;
---
<a
  href={`/games/${game.slug}`}
  data-title={game.title.toLowerCase()}
  data-tags={game.tags.join(' ').toLowerCase()}
  class="game-card group relative block rounded-3xl border border-white/40 bg-white/40 backdrop-blur-xl p-5 sm:p-6 shadow-glass hover:shadow-glass-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden"
>
  <!-- soft accent gradient blob -->
  <div
    class={`absolute -top-12 -right-12 w-40 h-40 rounded-full blur-3xl opacity-50 group-hover:opacity-80 transition pointer-events-none bg-gradient-to-br ${game.accent}`}
    aria-hidden="true"
  ></div>

  <div class="relative flex items-start justify-between gap-4">
    <div class="text-5xl sm:text-6xl drop-shadow-sm select-none" aria-hidden="true">{game.emoji}</div>
    <span class="text-slate-400 group-hover:text-fuchsia-600 group-hover:translate-x-1 transition text-xl">→</span>
  </div>

  <h3 class="relative mt-4 text-xl sm:text-2xl font-extrabold text-slate-900 font-display tracking-tight">
    {game.title}
  </h3>
  <p class="relative mt-1.5 text-sm text-slate-600 leading-relaxed line-clamp-2">{game.description}</p>

  <div class="relative mt-4 flex flex-wrap gap-1.5">
    {game.tags.map((t) => (
      <span class="text-[11px] font-semibold uppercase tracking-wider rounded-full bg-white/60 border border-white/70 text-slate-700 px-2.5 py-0.5">
        {t}
      </span>
    ))}
  </div>

  <div class="relative mt-5 flex items-center gap-2">
    <span class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-fuchsia-600 to-sky-500 text-white font-bold text-sm px-4 py-2 shadow-sm group-hover:opacity-90 transition">
      Play
    </span>
    <span class="text-xs text-slate-500">{game.difficulty}</span>
  </div>
</a>
