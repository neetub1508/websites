---
import type { Game } from '../lib/games';
interface Props {
  game: Game;
}
const { game } = Astro.props;
---
<a
  href={`/games/${game.slug}`}
  data-title={game.title.toLowerCase()}
  data-tags={game.tags.join(' ').toLowerCase()}
  class="game-card group relative block rounded-3xl ka-glass p-5 sm:p-6 hover:-translate-y-1 transition-all duration-300 overflow-hidden"
>
  <!-- soft accent gradient blob -->
  <div
    class={`absolute -top-12 -right-12 w-40 h-40 rounded-full blur-3xl opacity-50 group-hover:opacity-80 transition pointer-events-none bg-gradient-to-br ${game.accent}`}
    aria-hidden="true"
  ></div>

  <div class="relative flex items-start justify-between gap-4">
    <div class="text-5xl sm:text-6xl drop-shadow-sm select-none" aria-hidden="true">{game.emoji}</div>
    <span class="text-2xl transition group-hover:translate-x-1" style="color: rgb(var(--text-muted))" aria-hidden="true">→</span>
  </div>

  <h3 class="relative mt-4 text-xl sm:text-2xl font-extrabold font-display tracking-tight" style="color: rgb(var(--text))">
    {game.title}
  </h3>
  <p class="relative mt-1.5 text-sm leading-relaxed line-clamp-2" style="color: rgb(var(--text-soft))">{game.description}</p>

  <div class="relative mt-4 flex flex-wrap gap-1.5">
    {game.tags.map((t) => (
      <span class="text-[11px] font-semibold uppercase tracking-wider rounded-full px-2.5 py-0.5 ka-glass" style="color: rgb(var(--text-soft))">
        {t}
      </span>
    ))}
  </div>

  <div class="relative mt-5 flex items-center gap-2">
    <span class="ka-btn-accent text-sm py-2 px-4">Play</span>
    <span class="text-xs" style="color: rgb(var(--text-muted))">{game.difficulty}</span>
  </div>
</a>
