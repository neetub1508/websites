---
// Reusable ad placeholder. Reserves a fixed min-height so the real AdSense
// unit (dropped in later) cannot cause layout shift (protects Core Web Vitals).
interface Props {
  label?: string;
  minHeight?: string;
  width?: string;
}
const { label = 'Advertisement', minHeight = '250px', width } = Astro.props;
const style = `min-height:${minHeight}` + (width ? `;width:${width}` : '');
---
<div
  class="rounded-2xl border border-dashed border-white/60 bg-white/30 backdrop-blur-md grid place-items-center text-center shadow-glass"
  style={style}
  aria-label="Advertisement"
>
  <div>
    <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500">{label}</p>
    <p class="text-[11px] text-slate-400 mt-1">reserved space — no layout shift</p>
  </div>
</div>
