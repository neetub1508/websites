---
// Reusable ad placeholder. Reserves a fixed min-height so the real AdSense
// unit (dropped in later) cannot cause layout shift (protects Core Web Vitals).
interface Props {
  label?: string;
  minHeight?: string;
  width?: string;
}
const { label = 'Advertisement', minHeight = '250px', width } = Astro.props;
const style = `min-height:${minHeight}` + (width ? `;width:${width}` : '');
---
<div
  class="rounded-2xl border border-dashed ka-glass grid place-items-center text-center"
  style={`${style}; border-color: rgba(var(--glass-border), 0.45)`}
  aria-label="Advertisement"
>
  <div>
    <p class="text-[11px] font-semibold uppercase tracking-[0.2em]" style="color: rgb(var(--text-soft))">{label}</p>
    <p class="text-[11px] mt-1" style="color: rgb(var(--text-muted))">reserved space — no layout shift</p>
  </div>
</div>
