---
// Reusable FAQ accordion. Renders <details>/<summary> with glass styling.
interface Props {
  faqs: { q: string; a: string }[];
}
const { faqs } = Astro.props;
---
<div class="space-y-3">
  {faqs.map((f) => (
    <details class="group rounded-2xl ka-glass px-5 open:ka-glass-lg open:shadow-lg transition">
      <summary class="flex justify-between items-center cursor-pointer list-none font-bold py-4" style="color: rgb(var(--text))">
        <span>{f.q}</span>
        <span
          class="ml-4 shrink-0 grid place-items-center w-7 h-7 rounded-full transition group-open:rotate-45"
          style="background: rgba(var(--glass-bg), 0.7); color: rgb(var(--text-soft))"
          aria-hidden="true"
        >+</span>
      </summary>
      <p class="leading-relaxed pb-5 -mt-1" style="color: rgb(var(--text-soft))">{f.a}</p>
    </details>
  ))}
</div>
