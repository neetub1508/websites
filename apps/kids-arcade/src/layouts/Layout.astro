---
import AdSlot from '../components/AdSlot.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import '../styles/theme.css';
import { GAMES } from '../lib/games';

interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
const { title, description, schema } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const jsonLd = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang="en" data-theme="pastel">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#7c3aed" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Kids Arcade" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Preconnect to Google Fonts so theme-display fonts swap fast -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700;9..144,900&family=Fredoka:wght@500;600;700;800&family=Press+Start+2P&display=swap"
    />

    <!-- Theme tokens. Defines all three themes via [data-theme=...]. -->
    <!-- (imported above; bundled by Vite into the page CSS) -->

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8016259834034338"
      crossorigin="anonymous"
    ></script>

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <!-- Apply saved theme before first paint to prevent FOUC. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('ka_theme');
          if (t !== 'pastel' && t !== 'neon' && t !== 'illustrated') t = 'pastel';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'pastel');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased flex flex-col">
    <header class="sticky top-3 z-30 px-3">
      <div class="mx-auto max-w-6xl rounded-2xl ka-glass">
        <div class="px-5 h-16 flex items-center justify-between">
          <a href="/" class="flex items-center gap-2.5" aria-label="Kids Arcade home">
            <svg width="36" height="36" viewBox="0 0 40 40" fill="none" aria-hidden="true" class="shrink-0">
              <defs>
                <linearGradient id="ka-logo" x1="6" y1="4" x2="34" y2="36" gradientUnits="userSpaceOnUse">
                  <stop stop-color="rgb(var(--accent-1))" />
                  <stop offset="1" stop-color="rgb(var(--accent-2))" />
                </linearGradient>
              </defs>
              <rect x="2" y="2" width="36" height="36" rx="10" fill="url(#ka-logo)" />
              <rect x="3.5" y="3.5" width="33" height="33" rx="8.5" fill="none" stroke="#ffffff" stroke-opacity="0.4" stroke-width="1.25" />
              <text x="20" y="27.5" text-anchor="middle" font-family="ui-rounded, system-ui, sans-serif" font-size="20" font-weight="800" fill="#ffffff">🎮</text>
            </svg>
            <span class="font-extrabold text-[18px] tracking-tight font-display" style="color: rgb(var(--text))">Kids<span style="color: rgb(var(--accent-1))">Arcade</span></span>
          </a>
          <nav class="text-sm font-semibold hidden sm:flex items-center gap-6" style="color: rgb(var(--text-soft))">
            <a href="/" class="hover:opacity-80 transition">Games</a>
            <a href="/#why" class="hover:opacity-80 transition">Why Kids Arcade</a>
            <a href="/#faq" class="hover:opacity-80 transition">FAQ</a>
            <a href="/games/memory-match" class="ka-btn-accent text-sm py-1.5 px-3.5">Play now</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Sticky vertical side-rail ads — only on wide desktops (≥1560px) -->
    <div class="hidden min-[1560px]:block fixed left-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>
    <div class="hidden min-[1560px]:block fixed right-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-20 px-3 pb-3">
      <div class="mx-auto max-w-6xl rounded-3xl ka-glass">
        <div class="px-6 py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-sm">
          <div class="space-y-3">
            <div class="flex items-center gap-2 font-extrabold font-display" style="color: rgb(var(--text))">
              <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="36" height="36" rx="10" fill="url(#ka-logo)" />
                <text x="20" y="28" text-anchor="middle" font-family="ui-rounded, system-ui, sans-serif" font-size="20" font-weight="800" fill="#ffffff">🎮</text>
              </svg>
              Kids Arcade
            </div>
            <p class="leading-relaxed" style="color: rgb(var(--text-soft))">Free, original browser games for kids. Safe, no downloads, runs right in your browser.</p>
          </div>
          <div>
            <h3 class="font-bold mb-3" style="color: rgb(var(--text))">Games</h3>
            <ul class="space-y-2" style="color: rgb(var(--text-soft))">
              {GAMES.map((g) => (
                <li><a href={`/games/${g.slug}`} class="hover:opacity-80 transition">{g.title}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="font-bold mb-3" style="color: rgb(var(--text))">Explore</h3>
            <ul class="space-y-2" style="color: rgb(var(--text-soft))">
              <li><a href="/" class="hover:opacity-80 transition">All games</a></li>
              <li><a href="/#why" class="hover:opacity-80 transition">Why Kids Arcade</a></li>
              <li><a href="/#faq" class="hover:opacity-80 transition">FAQ</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold mb-3" style="color: rgb(var(--text))">Legal</h3>
            <ul class="space-y-2" style="color: rgb(var(--text-soft))">
              <li><a href="/about" class="hover:opacity-80 transition">About</a></li>
              <li><a href="/contact" class="hover:opacity-80 transition">Contact</a></li>
              <li><a href="/privacy" class="hover:opacity-80 transition">Privacy</a></li>
              <li><a href="/terms" class="hover:opacity-80 transition">Terms</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t" style="border-color: rgba(var(--glass-border), 0.5)">
          <p class="px-6 py-5 text-xs" style="color: rgb(var(--text-muted))">
            © 2026 Kids Arcade. Free for personal, family, and classroom use. Not affiliated with any third-party game publisher.
          </p>
        </div>
      </div>
    </footer>

    <ThemeSwitcher />
  </body>
</html>
