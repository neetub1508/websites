---
import AdSlot from '../components/AdSlot.astro';
import { GAMES } from '../lib/games';

interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
const { title, description, schema } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const jsonLd = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#7c3aed" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Kids Arcade" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8016259834034338"
      crossorigin="anonymous"
    ></script>

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body class="min-h-screen text-slate-900 antialiased flex flex-col selection:bg-fuchsia-200/60">
    <!-- Animated vibrant gradient background -->
    <div class="fixed inset-0 -z-20 bg-gradient-to-br from-fuchsia-300 via-sky-300 to-amber-200 bg-[length:200%_200%] animate-gradient-drift"></div>
    <div class="fixed inset-0 -z-10 bg-white/30 backdrop-blur-3xl"></div>

    <header class="sticky top-0 z-30 px-3 pt-3">
      <div class="mx-auto max-w-6xl rounded-2xl border border-white/40 bg-white/30 backdrop-blur-xl shadow-glass">
        <div class="px-5 h-16 flex items-center justify-between">
          <a href="/" class="flex items-center gap-2.5" aria-label="Kids Arcade home">
            <svg width="36" height="36" viewBox="0 0 40 40" fill="none" aria-hidden="true" class="shrink-0">
              <defs>
                <linearGradient id="ka-logo" x1="6" y1="4" x2="34" y2="36" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#a78bfa" />
                  <stop offset="1" stop-color="#ec4899" />
                </linearGradient>
              </defs>
              <rect x="2" y="2" width="36" height="36" rx="10" fill="url(#ka-logo)" />
              <rect x="3.5" y="3.5" width="33" height="33" rx="8.5" fill="none" stroke="#ffffff" stroke-opacity="0.4" stroke-width="1.25" />
              <text x="20" y="27.5" text-anchor="middle" font-family="ui-rounded, system-ui, sans-serif" font-size="20" font-weight="800" fill="#ffffff">🎮</text>
            </svg>
            <span class="font-extrabold text-[18px] tracking-tight text-slate-900 font-display">Kids<span class="text-fuchsia-600">Arcade</span></span>
          </a>
          <nav class="text-sm font-semibold text-slate-700 hidden sm:flex items-center gap-6">
            <a href="/" class="hover:text-fuchsia-700 transition">Games</a>
            <a href="/#why" class="hover:text-fuchsia-700 transition">Why Kids Arcade</a>
            <a href="/#faq" class="hover:text-fuchsia-700 transition">FAQ</a>
            <a href="/games/memory-match" class="rounded-xl bg-gradient-to-r from-fuchsia-600 to-sky-500 text-white px-4 py-1.5 shadow-sm hover:opacity-90 transition">Play now</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Sticky vertical side-rail ads — only on wide desktops (≥1560px) -->
    <div class="hidden min-[1560px]:block fixed left-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>
    <div class="hidden min-[1560px]:block fixed right-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-20 px-3 pb-3">
      <div class="mx-auto max-w-6xl rounded-3xl border border-white/40 bg-white/40 backdrop-blur-xl shadow-glass">
        <div class="px-6 py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-sm">
          <div class="space-y-3">
            <div class="flex items-center gap-2 font-extrabold text-slate-900 font-display">
              <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="36" height="36" rx="10" fill="url(#ka-logo)" />
                <text x="20" y="28" text-anchor="middle" font-family="ui-rounded, system-ui, sans-serif" font-size="20" font-weight="800" fill="#ffffff">🎮</text>
              </svg>
              Kids Arcade
            </div>
            <p class="text-slate-600 leading-relaxed">Free, original browser games for kids. Safe, no downloads, runs right in your browser.</p>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 mb-3">Games</h3>
            <ul class="space-y-2 text-slate-600">
              {GAMES.map((g) => (
                <li><a href={`/games/${g.slug}`} class="hover:text-fuchsia-700 transition">{g.title}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 mb-3">Explore</h3>
            <ul class="space-y-2 text-slate-600">
              <li><a href="/" class="hover:text-fuchsia-700 transition">All games</a></li>
              <li><a href="/#why" class="hover:text-fuchsia-700 transition">Why Kids Arcade</a></li>
              <li><a href="/#faq" class="hover:text-fuchsia-700 transition">FAQ</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 mb-3">Legal</h3>
            <ul class="space-y-2 text-slate-600">
              <li><a href="/about" class="hover:text-fuchsia-700 transition">About</a></li>
              <li><a href="/contact" class="hover:text-fuchsia-700 transition">Contact</a></li>
              <li><a href="/privacy" class="hover:text-fuchsia-700 transition">Privacy</a></li>
              <li><a href="/terms" class="hover:text-fuchsia-700 transition">Terms</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/40">
          <p class="px-6 py-5 text-xs text-slate-500">
            © 2026 Kids Arcade. Free for personal, family, and classroom use. Not affiliated with any third-party game publisher.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
