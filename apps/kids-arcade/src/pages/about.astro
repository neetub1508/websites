---
import Layout from '../layouts/Layout.astro';
const title = 'About Kids Arcade — Free, Original Browser Games for Kids';
const description = 'Kids Arcade builds free, original, kid-friendly browser games. Safe, no downloads, no sign-up. Here’s who we are and what we believe.';
---
<Layout title={title} description={description}>
  <section class="mx-auto max-w-3xl px-5 py-12">
    <div class="rounded-3xl border border-white/50 bg-white/50 backdrop-blur-xl p-6 sm:p-10 shadow-glass">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 font-display">About Kids Arcade</h1>

      <div class="mt-6 space-y-5 text-slate-700 leading-relaxed [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-900 [&_h2]:mt-6 [&_h2]:mb-2">
        <p>
          Kids Arcade is a small collection of <strong>original, free, kid-friendly browser games</strong> — built to load
          in seconds, run on any device, and stay out of the way of the fun.
        </p>

        <h2>What we believe</h2>
        <p>
          Kids’ games should be <strong>safe, simple, and respectful of attention</strong>. That means no sign-up walls, no
          chat features, no third-party trackers, and no games that try to upsell parents inside the play experience.
          We don’t collect personal information from children — and we don’t ask for it.
        </p>

        <h2>How the games are made</h2>
        <p>
          Every game on Kids Arcade is <strong>built by us, from scratch, in plain web code</strong>. That keeps the page
          light (no large engines, no embeds) and lets us run a quick quality pass on each release. The games are designed
          to develop <strong>memory, focus, and reaction time</strong> — evergreen skills wrapped in the classics kids already love.
        </p>

        <h2>How the site is supported</h2>
        <p>
          The site is supported by <strong>unobtrusive, kid-safe advertising</strong>. We don’t run promotions, sponsored
          placements, or paid reviews. If you spot something off, please <a href="/contact" class="text-fuchsia-700 underline">let us know</a>.
        </p>

        <h2>For parents and teachers</h2>
        <p>
          Kids Arcade is free for personal, family, and <strong>classroom use</strong>. No accounts. No installs. Just open the
          page and play. See our <a href="/privacy" class="text-fuchsia-700 underline">Privacy Policy</a> for the full story on
          data, or our <a href="/terms" class="text-fuchsia-700 underline">Terms of Service</a> for the legal fine print.
        </p>
      </div>
    </div>
  </section>
</Layout>
