---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import AdSlot from '../../components/AdSlot.astro';
import { GAMES } from '../../lib/games';

const game = GAMES.find((g) => g.id === 'snake')!;
const title = `${game.title} — Free Online Snake Game for Kids`;
const description = `Play ${game.title} free in your browser. ${game.description} Keyboard, touch, and swipe controls.`;
const canonical = Astro.site ? new URL(`/games/${game.slug}`, Astro.site).href : `/games/${game.slug}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: game.title,
    description: game.shortBlurb,
    genre: game.tags,
    playMode: 'SinglePlayer',
    applicationCategory: 'Game',
    operatingSystem: 'Any',
    gamePlatform: ['Web Browser'],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
      { '@type': 'ListItem', position: 2, name: game.title, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: game.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Layout title={title} description={description} schema={schema}>
  <section class="mx-auto max-w-5xl px-5 pt-6">
    <nav class="text-sm" style="color: rgb(var(--text-soft))" aria-label="Breadcrumb">
      <a href="/" class="hover:opacity-80">Home</a>
      <span class="mx-1.5">/</span>
      <span class="font-semibold" style="color: rgb(var(--text))">{game.title}</span>
    </nav>
  </section>

  <section class="mx-auto max-w-4xl px-5 pt-4 pb-6 text-center">
    <span class="inline-flex items-center gap-1.5 text-xs font-bold ka-glass rounded-full px-3 py-1.5" style="color: rgb(var(--text-soft))">
      <span class="w-1.5 h-1.5 rounded-full" style="background: rgb(var(--accent-1))"></span> {game.difficulty} · Single player
    </span>
    <h1 class="mt-4 text-5xl sm:text-6xl font-extrabold tracking-tight text-balance font-display leading-[1.05]">
      <span class="mr-2" aria-hidden="true">{game.emoji}</span>{game.title}
    </h1>
    <p class="mt-3 text-lg max-w-2xl mx-auto leading-relaxed" style="color: rgb(var(--text-soft))">{game.description}</p>
  </section>

  <section class="mx-auto max-w-4xl px-5">
    <div id="snake-root" class="rounded-3xl ka-glass-lg p-4 sm:p-6">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex flex-wrap items-center gap-3 sm:gap-5 text-sm font-semibold" style="color: rgb(var(--text-soft))">
          <span>Score: <span id="snake-score" style="color: rgb(var(--accent-1-ink))">0</span></span>
          <span>Best: <span id="snake-best" style="color: rgb(var(--accent-1-ink))">0</span></span>
        </div>
        <div class="flex items-center gap-2">
          <button id="snake-start" type="button" class="ka-btn-accent text-sm">Start</button>
          <button id="snake-pause" type="button" class="ka-btn-ghost text-sm">Pause</button>
        </div>
      </div>

      <div class="relative">
        <canvas id="snake-canvas" class="block w-full aspect-square rounded-2xl ka-board shadow-inner"></canvas>
        <div id="snake-overlay" class="absolute inset-0 grid place-content-center text-center rounded-2xl ka-glass" style="background: rgba(var(--glass-bg), 0.45)">
          <div class="px-6">
            <p class="text-3xl">🐍</p>
            <h3 id="snake-overlay-title" class="mt-1 text-xl font-extrabold font-display">Snake</h3>
            <p id="snake-overlay-msg" class="mt-1 font-semibold" style="color: rgb(var(--text-soft))">Use arrow keys, WASD, the D-pad, or swipe to play.</p>
          </div>
        </div>
      </div>

      <!-- On-screen D-pad (mobile-friendly) -->
      <div class="mt-5 grid grid-cols-3 gap-2 max-w-xs mx-auto sm:hidden">
        <span></span>
        <button id="snake-up" type="button" aria-label="Up" class="ka-btn-ghost text-xl py-2">▲</button>
        <span></span>
        <button id="snake-left" type="button" aria-label="Left" class="ka-btn-ghost text-xl py-2">◀</button>
        <span class="grid place-content-center text-2xl">🐍</span>
        <button id="snake-right" type="button" aria-label="Right" class="ka-btn-ghost text-xl py-2">▶</button>
        <span></span>
        <button id="snake-down" type="button" aria-label="Down" class="ka-btn-ghost text-xl py-2">▼</button>
        <span></span>
      </div>
      <!-- D-pad also visible on desktop as an accessibility helper -->
      <div class="mt-5 grid grid-cols-3 gap-2 max-w-xs mx-auto hidden sm:grid">
        <span></span>
        <button id="snake-up-d" type="button" aria-label="Up" class="ka-btn-ghost text-xl py-2">▲</button>
        <span></span>
        <button id="snake-left-d" type="button" aria-label="Left" class="ka-btn-ghost text-xl py-2">◀</button>
        <span class="grid place-content-center text-2xl">🐍</span>
        <button id="snake-right-d" type="button" aria-label="Right" class="ka-btn-ghost text-xl py-2">▶</button>
        <span></span>
        <button id="snake-down-d" type="button" aria-label="Down" class="ka-btn-ghost text-xl py-2">▼</button>
        <span></span>
      </div>
    </div>

    <p class="text-center text-xs mt-3" style="color: rgb(var(--text-muted))">
      🔒 No data leaves your device — scores stay in your browser.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 my-6">
    <AdSlot minHeight="120px" label="Advertisement" />
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-8">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight font-display">How to play {game.title}</h2>
    <ol class="mt-4 space-y-3 list-decimal list-inside leading-relaxed" style="color: rgb(var(--text-soft))">
      {game.howToPlay.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-10">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight font-display">Why it’s good for kids</h2>
    <ul class="mt-4 space-y-2.5">
      {game.benefits.map((b) => (
        <li class="flex gap-2.5" style="color: rgb(var(--text-soft))">
          <span class="mt-2 w-1.5 h-1.5 rounded-full shrink-0" style="background: rgb(var(--accent-2))"></span>
          <span class="leading-relaxed">{b}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-12">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight font-display">{game.title} — frequently asked questions</h2>
    <div class="mt-6">
      <Faq faqs={game.faqs} />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-12 mb-4">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold hover:opacity-80" style="color: rgb(var(--text-soft))">
      ← Back to all games
    </a>
  </section>
</Layout>

<script>
  import '../../games/snake.ts';
  document.getElementById('snake-up-d')?.addEventListener('click', () => document.getElementById('snake-up')?.click());
  document.getElementById('snake-down-d')?.addEventListener('click', () => document.getElementById('snake-down')?.click());
  document.getElementById('snake-left-d')?.addEventListener('click', () => document.getElementById('snake-left')?.click());
  document.getElementById('snake-right-d')?.addEventListener('click', () => document.getElementById('snake-right')?.click());
</script>
