---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import AdSlot from '../../components/AdSlot.astro';
import { GAMES } from '../../lib/games';

const game = GAMES.find((g) => g.id === 'snake')!;
const title = `${game.title} — Free Online Snake Game for Kids`;
const description = `Play ${game.title} free in your browser. ${game.description} Keyboard, touch, and swipe controls.`;
const canonical = Astro.site ? new URL(`/games/${game.slug}`, Astro.site).href : `/games/${game.slug}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: game.title,
    description: game.shortBlurb,
    genre: game.tags,
    playMode: 'SinglePlayer',
    applicationCategory: 'Game',
    operatingSystem: 'Any',
    gamePlatform: ['Web Browser'],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
      { '@type': 'ListItem', position: 2, name: game.title, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: game.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Layout title={title} description={description} schema={schema}>
  <section class="mx-auto max-w-5xl px-5 pt-6">
    <nav class="text-sm text-slate-700" aria-label="Breadcrumb">
      <a href="/" class="hover:text-fuchsia-700">Home</a>
      <span class="mx-1.5">/</span>
      <span class="text-slate-900 font-semibold">{game.title}</span>
    </nav>
  </section>

  <section class="mx-auto max-w-4xl px-5 pt-4 pb-6 text-center">
    <span class="inline-flex items-center gap-1.5 text-xs font-bold text-emerald-700 bg-white/60 ring-1 ring-white/70 rounded-full px-3 py-1 shadow-glass">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> {game.difficulty} · Single player
    </span>
    <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 text-balance font-display">
      <span class="mr-2" aria-hidden="true">{game.emoji}</span>{game.title}
    </h1>
    <p class="mt-3 text-lg text-slate-700 max-w-2xl mx-auto leading-relaxed">{game.description}</p>
  </section>

  <!-- Game mount point -->
  <section class="mx-auto max-w-4xl px-5">
    <div id="snake-root" class="rounded-3xl border border-white/50 bg-white/40 backdrop-blur-xl p-4 sm:p-6 shadow-glass-lg">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex flex-wrap items-center gap-3 sm:gap-5 text-sm font-semibold text-slate-800">
          <span>Score: <span id="snake-score" class="text-fuchsia-700">0</span></span>
          <span>Best: <span id="snake-best" class="text-fuchsia-700">0</span></span>
        </div>
        <div class="flex items-center gap-2">
          <button id="snake-start" type="button" class="rounded-xl bg-gradient-to-r from-fuchsia-600 to-sky-500 text-white font-bold text-sm px-4 py-2 shadow-sm hover:opacity-90 transition">Start</button>
          <button id="snake-pause" type="button" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-sm px-4 py-2 shadow-sm hover:bg-white/80 transition">Pause</button>
        </div>
      </div>

      <div class="relative">
        <canvas
          id="snake-canvas"
          class="block w-full aspect-square rounded-2xl border border-white/50 bg-gradient-to-br from-sky-50 to-emerald-50 shadow-inner"
        ></canvas>
        <div id="snake-overlay" class="absolute inset-0 grid place-content-center text-center rounded-2xl bg-white/40 backdrop-blur-md">
          <div class="px-6">
            <p class="text-3xl">🐍</p>
            <h3 id="snake-overlay-title" class="mt-1 text-xl font-extrabold text-slate-900 font-display">Snake</h3>
            <p id="snake-overlay-msg" class="mt-1 text-slate-700 font-semibold">Use arrow keys, WASD, the D-pad, or swipe to play.</p>
          </div>
        </div>
      </div>

      <!-- On-screen D-pad (mobile-friendly) -->
      <div class="mt-5 grid grid-cols-3 gap-2 max-w-xs mx-auto sm:hidden">
        <span></span>
        <button id="snake-up" type="button" aria-label="Up" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">▲</button>
        <span></span>
        <button id="snake-left" type="button" aria-label="Left" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">◀</button>
        <span class="grid place-content-center text-2xl">🐍</span>
        <button id="snake-right" type="button" aria-label="Right" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">▶</button>
        <span></span>
        <button id="snake-down" type="button" aria-label="Down" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">▼</button>
        <span></span>
      </div>
      <!-- D-pad also visible on desktop as an accessibility helper -->
      <div class="mt-5 grid grid-cols-3 gap-2 max-w-xs mx-auto hidden sm:grid">
        <span></span>
        <button id="snake-up-d" type="button" aria-label="Up" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">▲</button>
        <span></span>
        <button id="snake-left-d" type="button" aria-label="Left" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">◀</button>
        <span class="grid place-content-center text-2xl">🐍</span>
        <button id="snake-right-d" type="button" aria-label="Right" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">▶</button>
        <span></span>
        <button id="snake-down-d" type="button" aria-label="Down" class="rounded-xl bg-white/60 border border-white/70 text-slate-800 font-bold text-xl py-2 shadow-sm active:scale-95">▼</button>
        <span></span>
      </div>
    </div>

    <p class="text-center text-xs text-slate-600 mt-3">
      🔒 No data leaves your device — scores stay in your browser.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 my-6">
    <AdSlot minHeight="120px" label="Advertisement" />
  </section>

  <!-- How to play -->
  <section class="mx-auto max-w-3xl px-5 mt-8">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">How to play {game.title}</h2>
    <ol class="mt-4 space-y-3 list-decimal list-inside text-slate-700 leading-relaxed">
      {game.howToPlay.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <!-- Benefits -->
  <section class="mx-auto max-w-3xl px-5 mt-10">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">Why it’s good for kids</h2>
    <ul class="mt-4 space-y-2.5">
      {game.benefits.map((b) => (
        <li class="flex gap-2.5 text-slate-700">
          <span class="mt-2 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
          <span class="leading-relaxed">{b}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-5 mt-12">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">{game.title} — frequently asked questions</h2>
    <div class="mt-6">
      <Faq faqs={game.faqs} />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-12 mb-4">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-fuchsia-700">
      ← Back to all games
    </a>
  </section>
</Layout>

<script>
  import '../../games/snake.ts';
  // Wire the desktop D-pad to the same handlers as the mobile one.
  document.getElementById('snake-up-d')?.addEventListener('click', () => document.getElementById('snake-up')?.click());
  document.getElementById('snake-down-d')?.addEventListener('click', () => document.getElementById('snake-down')?.click());
  document.getElementById('snake-left-d')?.addEventListener('click', () => document.getElementById('snake-left')?.click());
  document.getElementById('snake-right-d')?.addEventListener('click', () => document.getElementById('snake-right')?.click());
</script>
