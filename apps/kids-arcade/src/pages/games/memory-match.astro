---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import AdSlot from '../../components/AdSlot.astro';
import { GAMES } from '../../lib/games';

const game = GAMES.find((g) => g.id === 'memory')!;
const title = `${game.title} — Free Online Memory Game for Kids`;
const description = `Play ${game.title} free in your browser. ${game.description} No downloads, no sign-up.`;
const canonical = Astro.site ? new URL(`/games/${game.slug}`, Astro.site).href : `/games/${game.slug}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: game.title,
    description: game.shortBlurb,
    genre: game.tags,
    playMode: 'SinglePlayer',
    applicationCategory: 'Game',
    operatingSystem: 'Any',
    gamePlatform: ['Web Browser'],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
      { '@type': 'ListItem', position: 2, name: game.title, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: game.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Layout title={title} description={description} schema={schema}>
  <section class="mx-auto max-w-5xl px-5 pt-6">
    <nav class="text-sm" style="color: rgb(var(--text-soft))" aria-label="Breadcrumb">
      <a href="/" class="hover:opacity-80">Home</a>
      <span class="mx-1.5">/</span>
      <span class="font-semibold" style="color: rgb(var(--text))">{game.title}</span>
    </nav>
  </section>

  <section class="mx-auto max-w-4xl px-5 pt-4 pb-6 text-center">
    <span class="inline-flex items-center gap-1.5 text-xs font-bold ka-glass rounded-full px-3 py-1.5" style="color: rgb(var(--text-soft))">
      <span class="w-1.5 h-1.5 rounded-full" style="background: rgb(var(--accent-1))"></span> {game.difficulty} · Single player
    </span>
    <h1 class="mt-4 text-5xl sm:text-6xl font-extrabold tracking-tight text-balance font-display leading-[1.05]">
      <span class="mr-2" aria-hidden="true">{game.emoji}</span>{game.title}
    </h1>
    <p class="mt-3 text-lg max-w-2xl mx-auto leading-relaxed" style="color: rgb(var(--text-soft))">{game.description}</p>
  </section>

  <!-- Game mount point -->
  <section class="mx-auto max-w-4xl px-5">
    <div id="memory-root" class="rounded-3xl ka-glass-lg p-4 sm:p-6">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex flex-wrap items-center gap-3 sm:gap-5 text-sm font-semibold" style="color: rgb(var(--text-soft))">
          <span>Moves: <span id="memory-moves" style="color: rgb(var(--accent-1-ink))">0</span></span>
          <span>Time: <span id="memory-time" style="color: rgb(var(--accent-1-ink))">0:00</span></span>
          <span>Best: <span id="memory-best" style="color: rgb(var(--accent-1-ink))">—</span></span>
        </div>
        <button id="memory-new" type="button" class="ka-btn-accent text-sm">New game</button>
      </div>

      <div id="memory-board" class="grid grid-cols-4 gap-2 sm:gap-3"></div>

      <!-- Win modal -->
      <div id="memory-win" class="hidden mt-5 rounded-2xl ka-glass-lg p-5 text-center">
        <p class="text-2xl">🎉</p>
        <h2 class="mt-1 text-xl font-extrabold font-display">You matched them all!</h2>
        <p id="memory-win-stats" class="mt-1 font-semibold" style="color: rgb(var(--text-soft))"></p>
        <p class="mt-1 text-sm" style="color: rgb(var(--text-soft))">Previous best: <span id="memory-prev-best" class="font-semibold" style="color: rgb(var(--text))">—</span></p>
        <button id="memory-win-close" type="button" class="mt-4 ka-btn-accent text-sm">Play again</button>
      </div>
    </div>

    <p class="text-center text-xs mt-3" style="color: rgb(var(--text-muted))">
      🔒 No data leaves your device — scores stay in your browser.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 my-6">
    <AdSlot minHeight="120px" label="Advertisement" />
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-8">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight font-display">How to play {game.title}</h2>
    <ol class="mt-4 space-y-3 list-decimal list-inside leading-relaxed" style="color: rgb(var(--text-soft))">
      {game.howToPlay.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-10">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight font-display">Why it’s good for kids</h2>
    <ul class="mt-4 space-y-2.5">
      {game.benefits.map((b) => (
        <li class="flex gap-2.5" style="color: rgb(var(--text-soft))">
          <span class="mt-2 w-1.5 h-1.5 rounded-full shrink-0" style="background: rgb(var(--accent-1))"></span>
          <span class="leading-relaxed">{b}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-12">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight font-display">{game.title} — frequently asked questions</h2>
    <div class="mt-6">
      <Faq faqs={game.faqs} />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-12 mb-4">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold hover:opacity-80" style="color: rgb(var(--text-soft))">
      ← Back to all games
    </a>
  </section>
</Layout>

<script>
  import '../../games/memory.ts';
</script>
