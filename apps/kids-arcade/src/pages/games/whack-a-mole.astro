---
import Layout from '../../layouts/Layout.astro';
import Faq from '../../components/Faq.astro';
import AdSlot from '../../components/AdSlot.astro';
import { GAMES } from '../../lib/games';

const game = GAMES.find((g) => g.id === 'whack')!;
const title = `${game.title} — Free Online Reaction Game for Kids`;
const description = `Play ${game.title} free in your browser. ${game.description} 30-second reaction rounds.`;
const canonical = Astro.site ? new URL(`/games/${game.slug}`, Astro.site).href : `/games/${game.slug}`;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: game.title,
    description: game.shortBlurb,
    genre: game.tags,
    playMode: 'SinglePlayer',
    applicationCategory: 'Game',
    operatingSystem: 'Any',
    gamePlatform: ['Web Browser'],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
      { '@type': 'ListItem', position: 2, name: game.title, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: game.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Layout title={title} description={description} schema={schema}>
  <section class="mx-auto max-w-5xl px-5 pt-6">
    <nav class="text-sm text-slate-700" aria-label="Breadcrumb">
      <a href="/" class="hover:text-fuchsia-700">Home</a>
      <span class="mx-1.5">/</span>
      <span class="text-slate-900 font-semibold">{game.title}</span>
    </nav>
  </section>

  <section class="mx-auto max-w-4xl px-5 pt-4 pb-6 text-center">
    <span class="inline-flex items-center gap-1.5 text-xs font-bold text-amber-700 bg-white/60 ring-1 ring-white/70 rounded-full px-3 py-1 shadow-glass">
      <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> {game.difficulty} · 30-second rounds
    </span>
    <h1 class="mt-4 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 text-balance font-display">
      <span class="mr-2" aria-hidden="true">{game.emoji}</span>{game.title}
    </h1>
    <p class="mt-3 text-lg text-slate-700 max-w-2xl mx-auto leading-relaxed">{game.description}</p>
  </section>

  <!-- Game mount point -->
  <section class="mx-auto max-w-4xl px-5">
    <div id="whack-root" class="rounded-3xl border border-white/50 bg-white/40 backdrop-blur-xl p-4 sm:p-6 shadow-glass-lg">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
        <div class="flex flex-wrap items-center gap-3 sm:gap-5 text-sm font-semibold text-slate-800">
          <span>Score: <span id="whack-score" class="text-fuchsia-700">0</span></span>
          <span>Best: <span id="whack-best" class="text-fuchsia-700">0</span></span>
          <span>Time: <span id="whack-time" class="text-fuchsia-700">30</span>s</span>
        </div>
        <button id="whack-start" type="button" class="rounded-xl bg-gradient-to-r from-fuchsia-600 to-sky-500 text-white font-bold text-sm px-4 py-2 shadow-sm hover:opacity-90 transition">
          Start
        </button>
      </div>

      <div class="relative">
        <div id="whack-board" class="grid grid-cols-3 gap-3 sm:gap-4"></div>
        <div id="whack-overlay" class="absolute inset-0 grid place-content-center text-center rounded-2xl bg-white/40 backdrop-blur-md">
          <div class="px-6">
            <p class="text-3xl">🔨</p>
            <h3 id="whack-overlay-title" class="mt-1 text-xl font-extrabold text-slate-900 font-display">Whack-a-Mole</h3>
            <p id="whack-overlay-msg" class="mt-1 text-slate-700 font-semibold">Press Start to begin a 30-second round.</p>
          </div>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-slate-600 mt-3">
      🔒 No data leaves your device — scores stay in your browser.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 my-6">
    <AdSlot minHeight="120px" label="Advertisement" />
  </section>

  <!-- How to play -->
  <section class="mx-auto max-w-3xl px-5 mt-8">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">How to play {game.title}</h2>
    <ol class="mt-4 space-y-3 list-decimal list-inside text-slate-700 leading-relaxed">
      {game.howToPlay.map((step) => <li>{step}</li>)}
    </ol>
  </section>

  <!-- Benefits -->
  <section class="mx-auto max-w-3xl px-5 mt-10">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">Why it’s good for kids</h2>
    <ul class="mt-4 space-y-2.5">
      {game.benefits.map((b) => (
        <li class="flex gap-2.5 text-slate-700">
          <span class="mt-2 w-1.5 h-1.5 rounded-full bg-amber-500 shrink-0"></span>
          <span class="leading-relaxed">{b}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-5 mt-12">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">{game.title} — frequently asked questions</h2>
    <div class="mt-6">
      <Faq faqs={game.faqs} />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 mt-12 mb-4">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-fuchsia-700">
      ← Back to all games
    </a>
  </section>
</Layout>

<script>
  import '../../games/whack.ts';
</script>
