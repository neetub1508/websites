---
import Layout from '../layouts/Layout.astro';
const title = 'Terms of Service — Kids Arcade';
const description = 'The terms governing your use of Kids Arcade’s free online games for kids.';
---
<Layout title={title} description={description}>
  <section class="mx-auto max-w-3xl px-5 py-12">
    <div class="rounded-3xl border border-white/50 bg-white/50 backdrop-blur-xl p-6 sm:p-10 shadow-glass">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 font-display">Terms of Service</h1>
      <p class="mt-2 text-sm text-slate-500">Last updated: 2026</p>

      <div class="mt-6 space-y-5 text-slate-700 leading-relaxed [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-900 [&_h2]:mt-6 [&_h2]:mb-2">
        <p>
          By using kids-arcade.com (the “Site”), you agree to these Terms of Service. If you do not agree, please do not
          use the Site.
        </p>

        <h2>Free for personal, family, and classroom use</h2>
        <p>
          The games on Kids Arcade are free to play for personal, family, and educational (classroom) use. You may not
          copy, redistribute, or resell the games or any of the site’s content without permission.
        </p>

        <h2>No warranty</h2>
        <p>
          The Site and its games are provided “as is” without warranties of any kind, express or implied, including
          accuracy, fitness for a particular purpose, or uninterrupted availability. We do our best to keep everything
          running smoothly, but we can’t guarantee the Site will be error-free.
        </p>

        <h2>Limitation of liability</h2>
        <p>
          To the fullest extent permitted by law, Kids Arcade shall not be liable for any loss or damage arising from
          your use of, or reliance on, the Site or its games.
        </p>

        <h2>Intellectual property</h2>
        <p>
          The design, text, code, and original game artwork on this Site are owned by Kids Arcade and may not be copied
          or redistributed without permission.
        </p>

        <h2>Children’s use</h2>
        <p>
          Kids Arcade is designed for kids of all ages. We do not collect personal information from children under 13.
          Parents and guardians are responsible for supervising their children’s use of the internet.
        </p>

        <h2>Changes</h2>
        <p>We may update these terms at any time. Continued use of the Site constitutes acceptance of the updated terms.</p>

        <h2>Contact</h2>
        <p>Questions? Visit our <a href="/contact" class="text-fuchsia-700 underline">contact page</a>.</p>
      </div>
    </div>
  </section>
</Layout>
