---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import GameCard from '../components/GameCard.astro';
import Faq from '../components/Faq.astro';
import AdSlot from '../components/AdSlot.astro';
import { GAMES } from '../lib/games';

const title = 'Kids Arcade — Free Online Games for Kids (Memory, Snake, Whack-a-Mole)';
const description =
  'Free, original browser games for kids. Play Memory Match, Snake, and Whack-a-Mole — no downloads, no sign-up, runs right in your browser.';

const faqs = [
  {
    q: 'Are the games really free?',
    a: 'Yes. Every game on Kids Arcade is 100% free to play — no sign-up, no in-app purchases, and no hidden fees. The site is supported by unobtrusive ads.',
  },
  {
    q: 'Do my kids need an account?',
    a: 'No. Kids can open any game and start playing immediately. We don’t ask for names, emails, birthdays, or any personal information.',
  },
  {
    q: 'Are these games safe for children?',
    a: 'Yes. The games are original, kid-friendly, and free of third-party trackers, chat features, or links to external sites. See our Privacy Policy for full details.',
  },
  {
    q: 'Do the games work on phones and tablets?',
    a: 'Yes. Every game is built to work with a touchscreen, a mouse, or a keyboard. Snakes and Whack-a-Mole also include on-screen controls and swipe support for mobile play.',
  },
  {
    q: 'Is the data we collect minimal?',
    a: 'Exactly. We do not collect personal information from kids. The only data stored on your device is optional high-score info in your browser, which you can clear at any time.',
  },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'Kids Arcade', url: Astro.site?.href, description },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Kids Arcade games',
    itemListElement: GAMES.map((g, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: g.title,
      url: new URL(`/games/${g.slug}`, Astro.site).href,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---
<Layout title={title} description={description} schema={schema}>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pt-12 pb-8 text-center">
    <span class="inline-flex items-center gap-1.5 text-xs font-bold text-fuchsia-700 bg-white/60 ring-1 ring-white/70 rounded-full px-3 py-1 shadow-glass">
      <span class="w-1.5 h-1.5 rounded-full bg-fuchsia-500 animate-pulse"></span> 100% free · No sign-up · Browser only
    </span>
    <h1 class="mt-5 text-4xl sm:text-6xl font-extrabold tracking-tight text-slate-900 text-balance font-display">
      Free <span class="bg-gradient-to-r from-fuchsia-600 via-sky-500 to-amber-500 bg-clip-text text-transparent">kids games</span> that just work
    </h1>
    <p class="mt-5 text-lg sm:text-xl text-slate-700 max-w-2xl mx-auto leading-relaxed">
      Three classic, kid-friendly games — Memory Match, Snake, and Whack-a-Mole — built for instant play in your browser. No downloads, no sign-up, no fuss.
    </p>

    <div class="mt-7">
      <SearchBar />
    </div>
  </section>

  <!-- Game grid -->
  <section class="mx-auto max-w-6xl px-5 pb-10">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {GAMES.map((g) => <GameCard game={g} />)}
    </div>
    <p id="no-results" class="hidden text-center text-slate-700 mt-8 font-semibold">No games match that search.</p>
  </section>

  <section class="mx-auto max-w-3xl px-5 my-6">
    <AdSlot minHeight="120px" label="Advertisement" />
  </section>

  <!-- Why Kids Arcade -->
  <section id="why" class="mx-auto max-w-5xl px-5 mt-8">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display text-center">Why kids love Kids Arcade</h2>
    <p class="mt-3 text-slate-700 text-center max-w-2xl mx-auto leading-relaxed">
      Each game is original, fast-loading, and built to be safe and fun for kids — with parents in mind.
    </p>
    <div class="mt-8 grid sm:grid-cols-3 gap-4">
      {[
        ['🎯', 'Instant play', 'No downloads, no sign-ups. Click a card and you’re in the game in under a second.'],
        ['🔒', 'Safe by design', 'No chat, no third-party trackers, no external links. We don’t collect any personal data.'],
        ['🧠', 'Brain-friendly fun', 'Memory, focus, and reaction time — games that are as good for growing minds as they are fun.'],
      ].map(([emoji, t, d]) => (
        <div class="rounded-2xl border border-white/50 bg-white/40 backdrop-blur-xl p-5 shadow-glass">
          <div class="text-3xl">{emoji}</div>
          <h3 class="mt-2 font-bold text-slate-900 font-display">{t}</h3>
          <p class="mt-1 text-sm text-slate-700 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-5 mt-16">
    <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 font-display">Frequently asked questions</h2>
    <div class="mt-6">
      <Faq faqs={faqs} />
    </div>
  </section>
</Layout>
