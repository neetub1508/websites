---
interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
const { title, description, schema } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const jsonLd = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0f766e" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="EasyPayCalc" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased flex flex-col selection:bg-teal-200/60">
    <header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/80 backdrop-blur-lg">
      <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 font-bold text-[17px] tracking-tight">
          <span class="grid place-items-center w-9 h-9 rounded-xl bg-gradient-to-br from-teal-500 to-emerald-600 text-white shadow-sm shadow-emerald-600/30">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </span>
          <span>EasyPay<span class="text-teal-600">Calc</span></span>
        </a>
        <nav class="text-sm font-medium text-slate-600 hidden sm:flex items-center gap-7">
          <a href="/" class="hover:text-teal-700 transition">Calculator</a>
          <a href="#how-it-works" class="hover:text-teal-700 transition">How it works</a>
          <a href="#faq" class="hover:text-teal-700 transition">FAQ</a>
          <a href="/" class="rounded-lg bg-slate-900 text-white px-3.5 py-1.5 hover:bg-slate-700 transition">All states</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 mt-20">
      <div class="mx-auto max-w-6xl px-5 py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-sm">
        <div class="space-y-3">
          <div class="flex items-center gap-2 font-bold">
            <span class="grid place-items-center w-7 h-7 rounded-lg bg-gradient-to-br from-teal-500 to-emerald-600 text-white text-xs">$</span>
            EasyPayCalc
          </div>
          <p class="text-slate-500 leading-relaxed">Free, instant take-home pay calculators for all 50 U.S. states.</p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Tool</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/" class="hover:text-teal-700">Paycheck calculator</a></li>
            <li><a href="#how-it-works" class="hover:text-teal-700">How it works</a></li>
            <li><a href="#faq" class="hover:text-teal-700">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Popular states</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/" class="hover:text-teal-700">California</a></li>
            <li><a href="/" class="hover:text-teal-700">Texas</a></li>
            <li><a href="/" class="hover:text-teal-700">New York</a></li>
            <li><a href="/" class="hover:text-teal-700">Florida</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Legal</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/about" class="hover:text-teal-700">About</a></li>
            <li><a href="/contact" class="hover:text-teal-700">Contact</a></li>
            <li><a href="/privacy" class="hover:text-teal-700">Privacy</a></li>
            <li><a href="/terms" class="hover:text-teal-700">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-slate-200">
        <p class="mx-auto max-w-6xl px-5 py-5 text-xs text-slate-400">
          © 2026 EasyPayCalc. Estimates for informational purposes only — not tax, legal, or financial advice.
        </p>
      </div>
    </footer>
  </body>
</html>
