---
interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
import AdSlot from '../components/AdSlot.astro';
import { popularStates } from '../lib/states';
import { GUIDES } from '../lib/guides';
const { title, description, schema } = Astro.props;
// Strip any trailing slash (root stays "/") so the canonical always matches the
// slash-less URLs used in the sitemap and internal links.
const canonicalPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonical = Astro.site ? new URL(canonicalPath, Astro.site).href : canonicalPath;
const jsonLd = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0f766e" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="EasyPayCalc" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8016259834034338"
      crossorigin="anonymous"
    ></script>

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased flex flex-col selection:bg-teal-200/60">
    <header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/80 backdrop-blur-lg">
      <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5" aria-label="EasyPayCalc home">
          <svg width="34" height="34" viewBox="0 0 40 40" fill="none" aria-hidden="true" class="shrink-0">
            <defs>
              <linearGradient id="epc-coin" x1="6" y1="4" x2="34" y2="36" gradientUnits="userSpaceOnUse">
                <stop stop-color="#2dd4bf" />
                <stop offset="1" stop-color="#0d9488" />
              </linearGradient>
            </defs>
            <circle cx="20" cy="20" r="18" fill="url(#epc-coin)" />
            <circle cx="20" cy="20" r="14.25" fill="none" stroke="#ffffff" stroke-opacity="0.35" stroke-width="1.25" />
            <text x="20" y="27.5" text-anchor="middle" font-family="ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif" font-size="22" font-weight="800" fill="#ffffff">$</text>
          </svg>
          <span class="font-extrabold text-[18px] tracking-tight text-slate-900">EasyPay<span class="text-teal-600">Calc</span></span>
        </a>
        <nav class="text-sm font-medium text-slate-600 hidden sm:flex items-center gap-7">
          <a href="/" class="hover:text-teal-700 transition">Calculator</a>
          <a href="/guides" class="hover:text-teal-700 transition">Guides</a>
          <a href="#faq" class="hover:text-teal-700 transition">FAQ</a>
          <a href="/" class="rounded-lg bg-slate-900 text-white px-3.5 py-1.5 hover:bg-slate-700 transition">All states</a>
        </nav>
      </div>
    </header>

    <!-- Sticky vertical side-rail ads — shown only on wide desktops (≥1500px) where the gutters have room. Hidden on mobile/tablet so they never crowd content. -->
    <div class="hidden min-[1560px]:block fixed left-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>
    <div class="hidden min-[1560px]:block fixed right-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 mt-20">
      <div class="mx-auto max-w-6xl px-5 py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-sm">
        <div class="space-y-3">
          <div class="flex items-center gap-2 font-bold">
            <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <circle cx="20" cy="20" r="18" fill="url(#epc-coin)" />
              <circle cx="20" cy="20" r="14.25" fill="none" stroke="#ffffff" stroke-opacity="0.35" stroke-width="1.25" />
              <text x="20" y="27.5" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="22" font-weight="800" fill="#ffffff">$</text>
            </svg>
            EasyPayCalc
          </div>
          <p class="text-slate-500 leading-relaxed">Free, instant take-home pay calculators for all 50 U.S. states.</p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Guides</h3>
          <ul class="space-y-2 text-slate-500">
            {GUIDES.slice(0, 4).map((g) => (
              <li><a href={`/guides/${g.slug}`} class="hover:text-teal-700">{g.title}</a></li>
            ))}
            <li><a href="/guides" class="text-teal-700 font-medium hover:text-teal-800">All guides →</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Popular states</h3>
          <ul class="space-y-2 text-slate-500">
            {popularStates.map((s) => (
              <li><a href={`/${s.slug}`} class="hover:text-teal-700">{s.name}</a></li>
            ))}
            <li><a href="/" class="text-teal-700 font-medium hover:text-teal-800">All states →</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Legal</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/about" class="hover:text-teal-700">About</a></li>
            <li><a href="/contact" class="hover:text-teal-700">Contact</a></li>
            <li><a href="/privacy" class="hover:text-teal-700">Privacy</a></li>
            <li><a href="/terms" class="hover:text-teal-700">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-slate-200">
        <p class="mx-auto max-w-6xl px-5 py-5 text-xs text-slate-400">
          © 2026 EasyPayCalc. Estimates for informational purposes only — not tax, legal, or financial advice.
        </p>
      </div>
    </footer>
  </body>
</html>
