---
import Layout from '../layouts/Layout.astro';
const title = 'Privacy Policy — EasyPayCalc';
const description = 'How EasyPayCalc handles your data: our calculators run in your browser and never send your salary anywhere. Details on cookies and advertising.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-3xl px-5 py-14 prose-slate">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Privacy Policy</h1>
    <p class="mt-2 text-sm text-slate-400">Last updated: 2026</p>

    <div class="mt-8 space-y-6 text-slate-600 leading-relaxed [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-900 [&_h2]:mt-8 [&_h2]:mb-2">
      <p>
        EasyPayCalc ("we", "us") respects your privacy. This policy explains what information is and isn’t
        collected when you use our paycheck calculators at easypaycalc.com.
      </p>

      <h2>The numbers you enter stay on your device</h2>
      <p>
        Our calculators run entirely in your browser. The salary, wage, and other figures you type are used only
        to compute your estimate on your own device — they are <strong>never transmitted to our servers</strong>,
        stored, or shared. We do not require an account and do not ask for your name, email, or financial details.
      </p>

      <h2>Cookies and advertising</h2>
      <p>
        We display advertising provided by Google AdSense to keep the site free. Third-party vendors, including
        Google, use cookies to serve ads based on your prior visits to this and other websites. Google’s use of
        advertising cookies enables it and its partners to serve ads to you based on your visit to our site and/or
        other sites on the Internet.
      </p>
      <p>
        You may opt out of personalized advertising by visiting
        <a href="https://www.google.com/settings/ads" class="text-teal-700 underline" rel="nofollow noopener" target="_blank">Google Ads Settings</a>,
        or opt out of third-party vendor cookies at
        <a href="https://www.aboutads.info" class="text-teal-700 underline" rel="nofollow noopener" target="_blank">aboutads.info</a>.
      </p>

      <h2>Analytics</h2>
      <p>
        We may use privacy-respecting, aggregate analytics to understand which pages are popular. This data is
        anonymous and is not linked to the figures you enter into the calculators.
      </p>

      <h2>Children’s privacy</h2>
      <p>EasyPayCalc is intended for a general audience and is not directed at children under 13.</p>

      <h2>Changes to this policy</h2>
      <p>We may update this policy from time to time. Material changes will be reflected by the date above.</p>

      <h2>Contact</h2>
      <p>Questions about this policy? Reach us via our <a href="/contact" class="text-teal-700 underline">contact page</a>.</p>
    </div>
  </section>
</Layout>
