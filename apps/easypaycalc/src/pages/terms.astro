---
import Layout from '../layouts/Layout.astro';
const title = 'Terms of Service — EasyPayCalc';
const description = 'The terms governing your use of EasyPayCalc’s free paycheck calculators, including our accuracy disclaimer.';
---

<Layout title={title} description={description}>
  <section class="mx-auto max-w-3xl px-5 py-14">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Terms of Service</h1>
    <p class="mt-2 text-sm text-slate-400">Last updated: 2026</p>

    <div class="mt-8 space-y-6 text-slate-600 leading-relaxed [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-900 [&_h2]:mt-8 [&_h2]:mb-2">
      <p>By using easypaycalc.com (the "Site"), you agree to these Terms of Service. If you do not agree, please do not use the Site.</p>

      <h2>Estimates only — not professional advice</h2>
      <p>
        Our calculators provide <strong>estimates for general informational and educational purposes only</strong>.
        They do not constitute tax, legal, accounting, or financial advice. Tax rules are complex and change over
        time, and your actual paycheck depends on factors we cannot account for, including your W-4 elections,
        local taxes, benefits, garnishments, and employer-specific deductions. Always confirm important figures
        with a qualified professional or the relevant tax authority (such as the IRS or your state revenue department).
      </p>

      <h2>No warranty</h2>
      <p>
        The Site and its calculators are provided "as is" without warranties of any kind, express or implied,
        including accuracy, completeness, or fitness for a particular purpose. We do not guarantee that any
        calculation is error-free or current.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        To the fullest extent permitted by law, EasyPayCalc shall not be liable for any loss or damage arising
        from your use of, or reliance on, the Site or its calculations.
      </p>

      <h2>Intellectual property</h2>
      <p>The design, text, and code of this Site are owned by EasyPayCalc and may not be copied or redistributed without permission.</p>

      <h2>Changes</h2>
      <p>We may update these terms at any time. Continued use of the Site constitutes acceptance of the updated terms.</p>

      <h2>Contact</h2>
      <p>Questions? Visit our <a href="/contact" class="text-teal-700 underline">contact page</a>.</p>
    </div>
  </section>
</Layout>
