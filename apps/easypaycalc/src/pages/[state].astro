---
import Layout from '../layouts/Layout.astro';
import Calculator from '../components/Calculator.astro';
import { STATES, toConfig } from '../lib/states';
import { TAX_YEAR } from '../lib/tax';

export function getStaticPaths() {
  return STATES.map((state) => ({ params: { state: state.slug }, props: { state } }));
}

const { state } = Astro.props;
const config = toConfig(state);
const others = STATES.filter((s) => s.slug !== state.slug);

const title = `${state.name} Paycheck Calculator ${TAX_YEAR} — Take-Home Pay After Taxes`;
const description = `Free ${state.name} paycheck calculator. Enter your salary or hourly wage to instantly see your ${TAX_YEAR} take-home pay after federal tax, Social Security, Medicare${state.hasIncomeTax ? `, and ${state.name} state tax` : ''}.`;

// --- Accurate, per-state FAQ (facts come from the state's data) ---
const faqs = [
  {
    q: `How much is taken out of a paycheck in ${state.name}?`,
    a: state.hasIncomeTax
      ? `In ${state.name}, federal income tax, Social Security (6.2%), Medicare (1.45%) and ${state.name} state income tax (${state.taxSummary})${state.extra.length ? ` plus ${state.extra.map((e) => e.name).join(' and ')}` : ''} are withheld. Total withholding typically lands around 25%–35% of gross pay, depending on income and filing status.`
      : `${state.name} has no state income tax, so only federal income tax, Social Security (6.2%) and Medicare (1.45%) are withheld. That usually means total withholding around 18%–28% of gross pay — lower than in states that tax income.`,
  },
  {
    q: 'What is take-home pay?',
    a: 'Take-home pay (net pay) is the amount that actually reaches your bank account after all taxes and deductions are subtracted from your gross salary. It is always lower than your headline salary.',
  },
  {
    q: `Does ${state.name} have a state income tax?`,
    a: state.hasIncomeTax
      ? `Yes. ${state.name} has a progressive state income tax (${state.taxSummary}), charged on top of federal income tax.`
      : `No. ${state.name} is one of the U.S. states with no state income tax on wages, which is why take-home pay here is higher than in most states.`,
  },
  {
    q: `Is this ${state.name} paycheck calculator accurate?`,
    a: `It gives a close estimate using ${TAX_YEAR} federal${state.hasIncomeTax ? ` and ${state.name}` : ''} tax brackets, the standard deduction and FICA. Your actual paycheck can vary based on local taxes, additional withholdings, benefits and your W-4. It is an estimate, not tax advice.`,
  },
];

// --- What's withheld (data-driven, always factually correct) ---
const withheld: [string, string][] = [
  ['Federal income tax', `Progressive 10%–37%, applied after the federal standard deduction ($15,000 single / $30,000 married for ${TAX_YEAR}).`],
  ['Social Security', '6.2% of wages up to the $176,100 wage base.'],
  ['Medicare', '1.45% of all wages, plus 0.9% above $200,000.'],
  state.hasIncomeTax
    ? [`${state.name} state income tax`, `Progressive ${state.taxSummary}.`]
    : [`${state.name} state income tax`, 'None — this state does not tax wage income.'],
  ...state.extra.map((e): [string, string] => [e.name, `${(e.rate * 100).toFixed(2)}% of wages.`]),
  ['401(k) — optional', 'Pre-tax contributions lower your taxable income for both federal and state tax.'],
];

const canonical = Astro.site ? new URL(`/${state.slug}`, Astro.site).href : `/${state.slug}`;
const schema = [
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
      { '@type': 'ListItem', position: 2, name: `${state.name} Paycheck Calculator`, item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: `${state.name} Paycheck Calculator`,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
];
---

<Layout title={title} description={description} schema={schema}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-teal-50/80 via-white to-white"></div>
    <div class="absolute -z-10 top-[-10%] right-[-5%] w-[40rem] h-[40rem] rounded-full bg-teal-200/20 blur-3xl"></div>

    <div class="mx-auto max-w-6xl px-5 pt-6">
      <!-- Breadcrumb -->
      <nav class="text-sm text-slate-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-teal-700">Home</a>
        <span class="mx-1.5">/</span>
        <span class="text-slate-600">{state.name} Paycheck Calculator</span>
      </nav>
    </div>

    <div class="mx-auto max-w-6xl px-5 pt-6 pb-6 text-center">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-teal-700 bg-teal-100/80 ring-1 ring-teal-200 rounded-full px-3 py-1">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span> {state.name} · {TAX_YEAR} tax year
      </span>
      <h1 class="mt-5 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 text-balance">
        {state.name} Paycheck Calculator
      </h1>
      <p class="mt-4 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
        See exactly what you keep after taxes in {state.name} — enter your pay for an instant, itemized take-home breakdown.
      </p>
    </div>

    <Calculator config={config} />
  </section>

  <!-- Unique per-state intro + how it works -->
  <section id="how-it-works" class="mx-auto max-w-3xl px-5 mt-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">How {state.name} take-home pay is calculated</h2>
    <p class="mt-4 text-slate-600 leading-relaxed">{state.intro}</p>

    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      {withheld.map(([t, d]) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
          <h3 class="font-semibold text-slate-800">{t}</h3>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>

    <ul class="mt-6 space-y-2.5">
      {state.highlights.map((h) => (
        <li class="flex gap-2.5 text-slate-600">
          <span class="mt-2 w-1.5 h-1.5 rounded-full bg-teal-500 shrink-0"></span>
          <span class="leading-relaxed">{h}</span>
        </li>
      ))}
    </ul>

    {state.localNote && (
      <div class="mt-6 rounded-2xl bg-teal-50 border border-teal-100 p-4 text-sm text-teal-900 leading-relaxed">
        <strong>Local note:</strong> {state.localNote}
      </div>
    )}
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-5 mt-14">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">{state.name} paycheck — frequently asked questions</h2>
    <div class="mt-6 space-y-3">
      {faqs.map((f) => (
        <details class="group rounded-2xl border border-slate-200 bg-white px-5 open:shadow-sm transition">
          <summary class="flex justify-between items-center cursor-pointer list-none font-semibold text-slate-800 py-4">
            {f.q}
            <span class="ml-4 shrink-0 grid place-items-center w-6 h-6 rounded-full bg-slate-100 text-slate-500 group-open:bg-teal-100 group-open:text-teal-700 group-open:rotate-45 transition">+</span>
          </summary>
          <p class="text-slate-600 leading-relaxed pb-5 -mt-1">{f.a}</p>
        </details>
      ))}
    </div>

    <p class="mt-10 text-xs text-slate-400 leading-relaxed">
      Disclaimer: This calculator provides estimates for educational purposes only using {TAX_YEAR} tax figures and
      does not constitute tax, legal, or financial advice. Actual withholding depends on your W-4, local taxes,
      benefits, and other factors. Verify with a qualified professional or the relevant tax authority.
    </p>
  </section>

  <!-- Internal links to other states (SEO) -->
  <section class="mx-auto max-w-3xl px-5 mt-14">
    <h2 class="text-lg font-bold text-slate-900">Other state paycheck calculators</h2>
    <div class="mt-4 flex flex-wrap gap-2.5">
      {others.map((s) => (
        <a href={`/${s.slug}`} class="rounded-full border border-slate-200 bg-white px-4 py-1.5 text-sm text-slate-700 hover:border-teal-300 hover:text-teal-700 transition">
          {s.name}
        </a>
      ))}
    </div>
  </section>
</Layout>
