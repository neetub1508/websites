---
import Layout from '../layouts/Layout.astro';
import { STATES, POPULAR_SLUGS, popularStates } from '../lib/states';
import { TAX_YEAR } from '../lib/tax';

// Show the 6 popular states by default (shared list); search reaches all 51.
const otherStates = STATES.filter((s) => !POPULAR_SLUGS.includes(s.slug));
const orderedStates = [...popularStates, ...otherStates];

const title = `Paycheck Calculator by State ${TAX_YEAR} — Free Take-Home Pay Calculator`;
const description = `Free paycheck calculators for every U.S. state. Enter your salary or hourly wage to instantly see your ${TAX_YEAR} take-home pay after federal tax, Social Security, Medicare and state taxes.`;

const faqs = [
  {
    q: 'What does a paycheck calculator do?',
    a: 'It estimates your net "take-home" pay — what actually reaches your bank account — by subtracting federal income tax, Social Security, Medicare and your state\'s taxes from your gross salary or hourly wage.',
  },
  {
    q: 'Why does take-home pay differ by state?',
    a: 'Federal tax and FICA are the same everywhere, but each state sets its own income tax. Nine states have no income tax at all, while others charge over 10%, so the same salary can yield very different take-home pay depending on where you live.',
  },
  {
    q: 'Is EasyPayCalc free?',
    a: 'Yes — every calculator is completely free, requires no sign-up, and runs entirely in your browser, so your salary information is never sent to a server.',
  },
];

const schema = [
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'EasyPayCalc', url: Astro.site?.href, description },
  { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---

<Layout title={title} description={description} schema={schema}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-teal-50/80 via-white to-white"></div>
    <div class="absolute -z-10 top-[-10%] right-[-5%] w-[40rem] h-[40rem] rounded-full bg-teal-200/20 blur-3xl"></div>

    <div class="mx-auto max-w-4xl px-5 pt-14 pb-8 text-center">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-teal-700 bg-teal-100/80 ring-1 ring-teal-200 rounded-full px-3 py-1">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span> Updated for {TAX_YEAR}
      </span>
      <h1 class="mt-5 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 text-balance">
        Paycheck Calculator <span class="text-teal-600">by State</span>
      </h1>
      <p class="mt-4 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
        Pick your state to see exactly what you take home after taxes — instant, itemized, and free.
        No sign-up, calculated right in your browser.
      </p>
    </div>

    <!-- State picker -->
    <div class="mx-auto max-w-4xl px-5 pb-6">
      <!-- Search / filter -->
      <div class="relative max-w-md mx-auto mb-6">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="state-search" type="search" autocomplete="off" placeholder="Search your state…"
          aria-label="Search for your state"
          class="w-full rounded-2xl border border-slate-300 bg-white pl-11 pr-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-teal-500 focus:ring-4 focus:ring-teal-500/15 outline-none transition" />
      </div>

      <p id="grid-label" class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Popular states</p>
      <div id="state-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {orderedStates.map((s) => {
          const isPopular = POPULAR_SLUGS.includes(s.slug);
          return (
            <a href={`/${s.slug}`} data-name={s.name.toLowerCase()} data-popular={isPopular ? 'true' : 'false'}
              class:list={[
                'state-card group flex items-center justify-between rounded-2xl border border-slate-200 bg-white p-4 shadow-sm hover:shadow-md hover:border-teal-300 transition',
                { hidden: !isPopular },
              ]}>
              <div>
                <div class="font-bold text-slate-900 group-hover:text-teal-700 transition">{s.name}</div>
                <div class="text-xs text-slate-400 mt-0.5">{s.taxSummary}</div>
              </div>
              <span class="text-slate-300 group-hover:text-teal-500 group-hover:translate-x-0.5 transition">→</span>
            </a>
          );
        })}
      </div>
      <p id="no-results" class="hidden text-center text-slate-500 mt-6">No state matches that search.</p>
      <p id="state-count" class="text-center text-xs text-slate-400 mt-5">Search above for any of all {STATES.length} states &amp; DC.</p>
    </div>
  </section>

  <script>
    const search = document.getElementById('state-search') as HTMLInputElement;
    const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>('.state-card'));
    const noResults = document.getElementById('no-results')!;
    const count = document.getElementById('state-count')!;
    const label = document.getElementById('grid-label')!;

    search.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      const searching = q.length > 0;
      let visible = 0;
      for (const card of cards) {
        // no query → show only the 6 popular; query → search across all 51
        const show = searching ? (card.dataset.name ?? '').includes(q) : card.dataset.popular === 'true';
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      }
      noResults.classList.toggle('hidden', visible > 0);
      count.classList.toggle('hidden', searching);
      label.textContent = searching ? 'Results' : 'Popular states';
    });

    // Enter jumps to the first visible match
    search.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;
      const first = cards.find((c) => !c.classList.contains('hidden'));
      if (first) window.location.href = first.href;
    });
  </script>

  <!-- How it works (national, unique copy) -->
  <section id="how-it-works" class="mx-auto max-w-3xl px-5 mt-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">How your take-home pay is calculated</h2>
    <p class="mt-4 text-slate-600 leading-relaxed">
      Your gross salary is reduced by several taxes before you’re paid. Three of them — federal income tax,
      Social Security and Medicare — are the same in every state. The fourth, <strong>state income tax</strong>,
      is where your location matters most: it can be zero or it can top 10%.
    </p>
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      {[
        ['Federal income tax', `Progressive 10%–37% on income after the federal standard deduction ($15,000 single / $30,000 married for ${TAX_YEAR}).`],
        ['FICA — Social Security & Medicare', '6.2% Social Security (up to $176,100) + 1.45% Medicare on all wages.'],
        ['State income tax', 'Set by each state — from 0% in no-tax states to over 10% in the highest.'],
        ['Pre-tax deductions', '401(k), HSA and similar contributions lower your taxable income and your tax bill.'],
      ].map(([t, d]) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
          <h3 class="font-semibold text-slate-800">{t}</h3>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-5 mt-14">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Frequently asked questions</h2>
    <div class="mt-6 space-y-3">
      {faqs.map((f) => (
        <details class="group rounded-2xl border border-slate-200 bg-white px-5 open:shadow-sm transition">
          <summary class="flex justify-between items-center cursor-pointer list-none font-semibold text-slate-800 py-4">
            {f.q}
            <span class="ml-4 shrink-0 grid place-items-center w-6 h-6 rounded-full bg-slate-100 text-slate-500 group-open:bg-teal-100 group-open:text-teal-700 group-open:rotate-45 transition">+</span>
          </summary>
          <p class="text-slate-600 leading-relaxed pb-5 -mt-1">{f.a}</p>
        </details>
      ))}
    </div>

    <p class="mt-10 text-xs text-slate-400 leading-relaxed">
      Disclaimer: EasyPayCalc provides estimates for educational purposes only using {TAX_YEAR} tax figures and does
      not constitute tax, legal, or financial advice. Verify with a qualified professional or the relevant tax authority.
    </p>
  </section>
</Layout>
