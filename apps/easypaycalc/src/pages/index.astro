---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'How much is taken out of a paycheck in California?',
    a: 'For most California workers, federal income tax, Social Security (6.2%), Medicare (1.45%), California state income tax (1%–12.3%), and State Disability Insurance (SDI, 1.1%) are withheld. On a typical salary, total withholding often lands around 25%–35% of gross pay, depending on income and filing status.',
  },
  {
    q: 'What is take-home pay?',
    a: 'Take-home pay (net pay) is the amount that actually reaches your bank account after all taxes and deductions are subtracted from your gross salary. It is always lower than your headline salary.',
  },
  {
    q: 'Does California have a state income tax?',
    a: 'Yes. California has one of the highest state income taxes in the country, with progressive rates from 1% up to 12.3% (plus a 1% surcharge above $1 million). This is on top of federal income tax.',
  },
  {
    q: 'Is this paycheck calculator accurate?',
    a: 'It gives a close estimate using current federal and California tax brackets, the standard deduction, FICA, and SDI. Your real paycheck can differ slightly based on local taxes, additional withholdings, benefits, and your W-4 settings. It is an estimate, not tax advice.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const title = 'California Paycheck Calculator 2025 — Take-Home Pay After Taxes';
const description =
  'Free California paycheck calculator. Enter your salary or hourly wage to instantly see your real take-home pay after federal tax, Social Security, Medicare, CA state tax and SDI.';
---

<Layout title={title} description={description} schema={faqSchema}>
  <!-- Hero + Calculator -->
  <section class="relative overflow-hidden">
    <!-- soft background flourish -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-teal-50/80 via-white to-white"></div>
    <div class="absolute -z-10 top-[-10%] right-[-5%] w-[40rem] h-[40rem] rounded-full bg-teal-200/20 blur-3xl"></div>

    <div class="mx-auto max-w-6xl px-5 pt-12 pb-6 text-center">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-teal-700 bg-teal-100/80 ring-1 ring-teal-200 rounded-full px-3 py-1">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span> California · 2025 tax year
      </span>
      <h1 class="mt-5 text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 text-balance">
        California Paycheck Calculator
      </h1>
      <p class="mt-4 text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
        See exactly what you keep after taxes — enter your pay and get an instant, itemized take-home breakdown.
      </p>
    </div>

    <!-- Calculator card -->
    <div class="mx-auto max-w-6xl px-5 pb-4">
      <div class="grid lg:grid-cols-12 gap-0 rounded-3xl border border-slate-200 bg-white shadow-xl shadow-slate-200/60 overflow-hidden">
        <!-- Inputs -->
        <div class="lg:col-span-5 p-6 sm:p-8 border-b lg:border-b-0 lg:border-r border-slate-100">
          <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-5">Your details</h2>

          <div class="grid grid-cols-2 gap-1 p-1 bg-slate-100 rounded-xl mb-6">
            <button type="button" data-paytype="salary" class="paytype-btn rounded-lg py-2 text-sm font-semibold transition-all">Salary</button>
            <button type="button" data-paytype="hourly" class="paytype-btn rounded-lg py-2 text-sm font-semibold transition-all">Hourly</button>
          </div>

          <label class="block mb-2">
            <span id="amount-label" class="block text-sm font-semibold text-slate-700 mb-1.5">Annual salary</span>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-lg font-medium">$</span>
              <input id="amount" type="number" inputmode="decimal" min="0" value="85000"
                class="w-full rounded-2xl border border-slate-300 pl-9 pr-4 py-3.5 text-2xl font-bold text-slate-900 focus:border-teal-500 focus:ring-4 focus:ring-teal-500/15 outline-none transition" />
            </div>
          </label>
          <input id="amount-range" type="range" min="20000" max="400000" step="1000" value="85000"
            class="w-full accent-teal-600 cursor-pointer mb-6" />

          <label id="hours-wrap" class="hidden mb-6">
            <span class="block text-sm font-semibold text-slate-700 mb-1.5">Hours per week</span>
            <input id="hours" type="number" inputmode="decimal" min="0" value="40"
              class="w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-teal-500 focus:ring-4 focus:ring-teal-500/15 outline-none transition" />
          </label>

          <div class="grid sm:grid-cols-2 gap-4 mb-5">
            <label class="block">
              <span class="block text-sm font-semibold text-slate-700 mb-1.5">Pay frequency</span>
              <select id="frequency"
                class="w-full rounded-2xl border border-slate-300 px-3.5 py-3 bg-white focus:border-teal-500 focus:ring-4 focus:ring-teal-500/15 outline-none transition">
                <option value="52">Weekly</option>
                <option value="26" selected>Every 2 weeks</option>
                <option value="24">Twice a month</option>
                <option value="12">Monthly</option>
              </select>
            </label>
            <label class="block">
              <span class="block text-sm font-semibold text-slate-700 mb-1.5">Filing status</span>
              <select id="filing"
                class="w-full rounded-2xl border border-slate-300 px-3.5 py-3 bg-white focus:border-teal-500 focus:ring-4 focus:ring-teal-500/15 outline-none transition">
                <option value="single" selected>Single</option>
                <option value="married">Married jointly</option>
              </select>
            </label>
          </div>

          <label class="block">
            <span class="block text-sm font-semibold text-slate-700 mb-1.5">401(k) contribution
              <span class="text-slate-400 font-normal">— optional</span>
            </span>
            <div class="relative">
              <input id="retirement" type="number" inputmode="decimal" min="0" max="90" value="0"
                class="w-full rounded-2xl border border-slate-300 pl-4 pr-10 py-3 focus:border-teal-500 focus:ring-4 focus:ring-teal-500/15 outline-none transition" />
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400">% of pay</span>
            </div>
          </label>
        </div>

        <!-- Result -->
        <div class="lg:col-span-7 p-6 sm:p-8 bg-gradient-to-br from-slate-50 to-white">
          <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8">
            <!-- Donut -->
            <div class="relative shrink-0">
              <svg width="180" height="180" viewBox="0 0 180 180" class="-rotate-90">
                <circle cx="90" cy="90" r="70" fill="none" stroke="#f1f5f9" stroke-width="26" />
                <g id="donut"></g>
              </svg>
              <div class="absolute inset-0 grid place-content-center text-center">
                <span class="text-xs font-medium text-slate-400">Take-home</span>
                <span id="net-pct" class="text-3xl font-extrabold text-slate-900 leading-none">0%</span>
              </div>
            </div>

            <!-- Headline numbers -->
            <div class="text-center sm:text-left">
              <p class="text-sm font-medium text-slate-400">Your take-home pay</p>
              <div class="flex items-baseline justify-center sm:justify-start gap-1.5 mt-1">
                <span id="net-period" class="text-5xl font-extrabold tracking-tight text-teal-600">$0</span>
                <span id="period-label" class="text-slate-400 font-medium">/ paycheck</span>
              </div>
              <p class="text-slate-500 mt-2 text-sm">
                <span id="net-annual" class="font-bold text-slate-700">$0</span> per year
              </p>
              <p class="text-slate-500 text-sm">
                Effective tax rate <span id="eff-rate" class="font-bold text-slate-700">0%</span>
              </p>
            </div>
          </div>

          <!-- Breakdown -->
          <div class="mt-7 rounded-2xl bg-white border border-slate-100 p-1">
            <table class="w-full text-sm">
              <tbody id="breakdown" class="divide-y divide-slate-100"></tbody>
            </table>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-slate-400 mt-4">
        🔒 Calculated entirely in your browser — your salary is never sent anywhere.
      </p>
    </div>
  </section>

  <!-- Ad slot: far below the interactive controls (AdSense ≥150px spacing rule) -->
  <div class="mx-auto max-w-5xl px-5 mt-10">
    <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 text-slate-400 text-sm grid place-items-center h-28">
      Ad placeholder
    </div>
  </div>

  <!-- How it works -->
  <section id="how-it-works" class="mx-auto max-w-3xl px-5 mt-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">How California take-home pay is calculated</h2>
    <p class="mt-4 text-slate-600 leading-relaxed">
      Your <strong>gross salary</strong> is never what lands in your bank account. In California, several
      deductions come out of every paycheck before you receive your <strong>net (take-home) pay</strong>:
    </p>
    <div class="mt-6 grid sm:grid-cols-2 gap-4">
      {[
        ['Federal income tax', 'Progressive 10%–37%, applied after the federal standard deduction ($15,000 single / $30,000 married for 2025).'],
        ['Social Security', '6.2% of wages up to the $176,100 wage base.'],
        ['Medicare', '1.45% of all wages, plus 0.9% above $200,000.'],
        ['California state tax', 'Progressive 1%–12.3% — among the highest in the U.S.'],
        ['CA State Disability (SDI)', '1.1% of wages, funding state disability and paid family leave.'],
        ['401(k) — optional', 'Pre-tax contributions lower your taxable income for both federal and state tax.'],
      ].map(([t, d]) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50/60 p-4">
          <h3 class="font-semibold text-slate-800">{t}</h3>
          <p class="text-sm text-slate-500 mt-1 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-5 mt-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">Frequently asked questions</h2>
    <div class="mt-6 space-y-3">
      {faqs.map((f) => (
        <details class="group rounded-2xl border border-slate-200 bg-white px-5 open:shadow-sm transition">
          <summary class="flex justify-between items-center cursor-pointer list-none font-semibold text-slate-800 py-4">
            {f.q}
            <span class="ml-4 shrink-0 grid place-items-center w-6 h-6 rounded-full bg-slate-100 text-slate-500 group-open:bg-teal-100 group-open:text-teal-700 group-open:rotate-45 transition">+</span>
          </summary>
          <p class="text-slate-600 leading-relaxed pb-5 -mt-1">{f.a}</p>
        </details>
      ))}
    </div>

    <p class="mt-10 text-xs text-slate-400 leading-relaxed">
      Disclaimer: This calculator provides estimates for educational purposes only using 2025 tax figures and
      does not constitute tax, legal, or financial advice. Actual withholding depends on your W-4, local taxes,
      benefits, and other factors. Verify with a qualified professional or the IRS and California FTB.
    </p>
  </section>
</Layout>

<script>
  import { computePaycheck, CALIFORNIA, type FilingStatus } from '../lib/tax';

  const $ = (id: string) => document.getElementById(id)!;
  const usd0 = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
  const usd2 = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });

  const COLORS: Record<string, string> = {
    'Take-home pay': '#0d9488',
    'Federal income tax': '#1e293b',
    'Social Security': '#475569',
    Medicare: '#94a3b8',
    'California state tax': '#f59e0b',
    'CA SDI': '#fcd34d',
    '401(k)': '#38bdf8',
  };

  let payType: 'salary' | 'hourly' = 'salary';

  const amountEl = $('amount') as HTMLInputElement;
  const rangeEl = $('amount-range') as HTMLInputElement;
  const hoursEl = $('hours') as HTMLInputElement;
  const hoursWrap = $('hours-wrap');
  const freqEl = $('frequency') as HTMLSelectElement;
  const filingEl = $('filing') as HTMLSelectElement;
  const retirementEl = $('retirement') as HTMLInputElement;

  const FREQ_LABEL: Record<string, string> = {
    '52': '/ week', '26': '/ paycheck', '24': '/ paycheck', '12': '/ month',
  };
  const R = 70;
  const CIRC = 2 * Math.PI * R;

  function setPayType(t: 'salary' | 'hourly') {
    payType = t;
    document.querySelectorAll<HTMLButtonElement>('.paytype-btn').forEach((b) => {
      const active = b.dataset.paytype === t;
      b.classList.toggle('bg-white', active);
      b.classList.toggle('shadow-sm', active);
      b.classList.toggle('text-teal-700', active);
      b.classList.toggle('text-slate-500', !active);
    });
    hoursWrap.classList.toggle('hidden', t !== 'hourly');
    $('amount-label').textContent = t === 'salary' ? 'Annual salary' : 'Hourly wage';
    rangeEl.classList.toggle('hidden', t !== 'salary');
    if (t === 'salary') { amountEl.value = '85000'; rangeEl.value = '85000'; }
    else { amountEl.value = '40'; }
    render();
  }

  function render() {
    const amount = parseFloat(amountEl.value) || 0;
    const hours = parseFloat(hoursEl.value) || 0;
    const annualGross = payType === 'salary' ? amount : amount * hours * 52;
    const payPeriods = parseInt(freqEl.value, 10);
    const filing = filingEl.value as FilingStatus;
    const pct = Math.min(90, Math.max(0, parseFloat(retirementEl.value) || 0));
    const pretax = annualGross * (pct / 100);

    const r = computePaycheck({ annualGross, filing, state: CALIFORNIA, payPeriods, pretax });

    ($('net-period') as HTMLElement).textContent = usd0.format(r.perPeriodNet);
    $('period-label').textContent = FREQ_LABEL[freqEl.value] ?? '/ paycheck';
    $('net-annual').textContent = usd0.format(r.annualNet);
    $('eff-rate').textContent = (r.effectiveRate * 100).toFixed(1) + '%';
    const netPct = annualGross > 0 ? Math.round((r.annualNet / annualGross) * 100) : 0;
    $('net-pct').textContent = netPct + '%';

    // Donut + segments
    const segments = [
      { label: 'Take-home pay', amount: r.annualNet },
      ...r.deductions.map((d) => ({ label: d.label, amount: d.amount })),
    ];
    if (r.pretax > 0) segments.push({ label: '401(k)', amount: r.pretax });
    const total = segments.reduce((s, x) => s + x.amount, 0) || 1;

    let offset = 0;
    $('donut').innerHTML = segments
      .filter((s) => s.amount > 0)
      .map((s) => {
        const frac = s.amount / total;
        const len = frac * CIRC;
        const c = COLORS[s.label] ?? '#cbd5e1';
        const circle = `<circle cx="90" cy="90" r="${R}" fill="none" stroke="${c}" stroke-width="26"
          stroke-dasharray="${len} ${CIRC - len}" stroke-dashoffset="${-offset}"><title>${s.label}</title></circle>`;
        offset += len;
        return circle;
      })
      .join('');

    // Breakdown rows
    const row = (label: string, val: string, kind: 'head' | 'ded' | 'net' = 'ded', color?: string) => {
      const dot = color ? `<span style="background:${color}" class="inline-block w-2.5 h-2.5 rounded-full mr-2 align-middle"></span>` : '';
      const cls = kind === 'net' ? 'font-bold text-slate-900' : kind === 'head' ? 'font-bold text-slate-900' : 'text-slate-600';
      const valCls = kind === 'ded' ? 'text-rose-500' : 'text-slate-900 font-bold';
      return `<tr class="${cls}"><td class="py-2.5 px-3">${dot}${label}</td><td class="py-2.5 px-3 text-right ${valCls}">${val}</td></tr>`;
    };

    $('breakdown').innerHTML = [
      row('Gross pay', usd0.format(r.annualGross), 'head'),
      ...(r.pretax > 0 ? [row('401(k) contribution', '−' + usd0.format(r.pretax), 'ded', COLORS['401(k)'])] : []),
      ...r.deductions.map((d) => row(d.label, '−' + usd0.format(d.amount), 'ded', COLORS[d.label])),
      row('Take-home (annual)', usd0.format(r.annualNet), 'net', COLORS['Take-home pay']),
    ].join('');
  }

  // Sync range <-> number input
  rangeEl.addEventListener('input', () => { amountEl.value = rangeEl.value; render(); });
  amountEl.addEventListener('input', () => {
    if (payType === 'salary') rangeEl.value = amountEl.value;
    render();
  });
  [hoursEl, freqEl, filingEl, retirementEl].forEach((el) => el.addEventListener('input', render));
  document.querySelectorAll<HTMLButtonElement>('.paytype-btn').forEach((b) =>
    b.addEventListener('click', () => setPayType(b.dataset.paytype as 'salary' | 'hourly')),
  );

  setPayType('salary');
</script>
