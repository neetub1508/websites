---
interface Props {
  title: string;
  description: string;
  schema?: object | object[];
}
import AdSlot from '../components/AdSlot.astro';
import { ADSENSE_CLIENT } from '../lib/config';
import { GUIDES } from '../lib/guides';
const { title, description, schema } = Astro.props;
// Strip any trailing slash (root stays "/") so the canonical always matches the
// slash-less URLs used in the sitemap and internal links.
const canonicalPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonical = Astro.site ? new URL(canonicalPath, Astro.site).href : canonicalPath;
const jsonLd = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#4f46e5" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="1099 Estimator" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Google AdSense — loads only when this project's OWN publisher ID is set
         in src/lib/config.ts (ADSENSE_CLIENT). Never reuse another site's ID. -->
    {ADSENSE_CLIENT && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
        crossorigin="anonymous"
      ></script>
    )}

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased flex flex-col selection:bg-indigo-200/60">
    <header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/80 backdrop-blur-lg">
      <div class="mx-auto max-w-6xl px-5 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5" aria-label="1099 Estimator home">
          <svg width="34" height="34" viewBox="0 0 40 40" fill="none" aria-hidden="true" class="shrink-0">
            <defs>
              <linearGradient id="e99-coin" x1="6" y1="4" x2="34" y2="36" gradientUnits="userSpaceOnUse">
                <stop stop-color="#6366f1" />
                <stop offset="1" stop-color="#7c3aed" />
              </linearGradient>
            </defs>
            <circle cx="20" cy="20" r="18" fill="url(#e99-coin)" />
            <circle cx="20" cy="20" r="14.25" fill="none" stroke="#ffffff" stroke-opacity="0.35" stroke-width="1.25" />
            <text x="20" y="27.5" text-anchor="middle" font-family="ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif" font-size="22" font-weight="800" fill="#ffffff">$</text>
          </svg>
          <span class="font-extrabold text-[18px] tracking-tight text-slate-900"><span class="text-indigo-600">1099</span> Estimator</span>
        </a>
        <nav class="text-sm font-medium text-slate-600 hidden sm:flex items-center gap-7">
          <a href="/" class="hover:text-indigo-700 transition">Calculator</a>
          <a href="/#how-it-works" class="hover:text-indigo-700 transition">How it works</a>
          <a href="/guides" class="hover:text-indigo-700 transition">Guides</a>
          <a href="/#faq" class="hover:text-indigo-700 transition">FAQ</a>
        </nav>
      </div>
    </header>

    <!-- Sticky vertical side-rail ads — shown only on wide desktops (≥1500px) where the gutters have room. Hidden on mobile/tablet so they never crowd content. -->
    <div class="hidden min-[1560px]:block fixed left-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>
    <div class="hidden min-[1560px]:block fixed right-5 top-1/2 -translate-y-1/2 z-10">
      <AdSlot width="160px" minHeight="600px" label="Advertisement" />
    </div>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-slate-50 mt-20">
      <div class="mx-auto max-w-6xl px-5 py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-sm">
        <div class="space-y-3">
          <div class="flex items-center gap-2 font-bold">
            <svg width="26" height="26" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              <circle cx="20" cy="20" r="18" fill="url(#e99-coin)" />
              <circle cx="20" cy="20" r="14.25" fill="none" stroke="#ffffff" stroke-opacity="0.35" stroke-width="1.25" />
              <text x="20" y="27.5" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="22" font-weight="800" fill="#ffffff">$</text>
            </svg>
            1099 Estimator
          </div>
          <p class="text-slate-500 leading-relaxed">Free, instant self-employment &amp; 1099 tax calculator for U.S. freelancers, gig workers, and contractors.</p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Tool</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/" class="hover:text-indigo-700">1099 tax calculator</a></li>
            <li><a href="/#how-it-works" class="hover:text-indigo-700">How it works</a></li>
            <li><a href="/#quarterly" class="hover:text-indigo-700">Quarterly taxes</a></li>
            <li><a href="/#faq" class="hover:text-indigo-700">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Guides</h3>
          <ul class="space-y-2 text-slate-500">
            {GUIDES.slice(0, 4).map((g) => (
              <li><a href={`/guides/${g.slug}`} class="hover:text-indigo-700">{g.title}</a></li>
            ))}
            <li><a href="/guides" class="text-indigo-700 font-medium hover:text-indigo-800">All guides →</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-slate-800 mb-3">Legal</h3>
          <ul class="space-y-2 text-slate-500">
            <li><a href="/about" class="hover:text-indigo-700">About</a></li>
            <li><a href="/contact" class="hover:text-indigo-700">Contact</a></li>
            <li><a href="/privacy" class="hover:text-indigo-700">Privacy</a></li>
            <li><a href="/terms" class="hover:text-indigo-700">Terms</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-slate-200">
        <p class="mx-auto max-w-6xl px-5 py-5 text-xs text-slate-400">
          © 2026 1099 Estimator. Estimates for informational purposes only — not tax, legal, or financial advice.
        </p>
      </div>
    </footer>
  </body>
</html>
