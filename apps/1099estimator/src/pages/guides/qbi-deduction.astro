---
import Layout from '../../layouts/Layout.astro';

const title = 'What Is the QBI Deduction? (Qualified Business Income, 2025–2026)';
const description =
  'A plain-English guide to the 20% QBI deduction (Section 199A) for freelancers and the self-employed: what it is, who qualifies, how the income thresholds and SSTB limits work, and a worked example.';

const faqs = [
  {
    q: 'What is the QBI deduction in simple terms?',
    a: 'The Qualified Business Income (QBI) deduction lets most self-employed people and pass-through business owners deduct up to 20% of their qualified business profit from their taxable income. It was created by the 2017 Tax Cuts and Jobs Act under Section 199A and lowers your federal income tax bill.',
  },
  {
    q: 'Does the QBI deduction reduce self-employment tax?',
    a: 'No. The QBI deduction only reduces your federal income tax. It does not lower the 15.3% self-employment tax, which is calculated separately on your net profit before any QBI deduction is applied.',
  },
  {
    q: 'Do freelancers and sole proprietors qualify for the QBI deduction?',
    a: 'Usually yes. Sole proprietors, freelancers, gig workers, single-member LLCs, partnerships, and S-corporation owners generally have pass-through income that can qualify. Below the annual income thresholds, most people simply take 20% of their qualified profit.',
  },
  {
    q: 'What is an SSTB and why does it matter?',
    a: 'An SSTB is a "specified service trade or business" — fields such as consulting, law, accounting, health, and financial services where the main asset is the reputation or skill of the people involved. If your taxable income rises above the annual threshold and into the phase-out range, the QBI deduction shrinks and eventually disappears for SSTBs.',
  },
  {
    q: 'How is the QBI deduction actually calculated?',
    a: 'For most people it is 20% of qualified business income, but it is capped at 20% of your taxable income (minus net capital gains). So the deduction is the lesser of those two figures. Above the income thresholds, a W-2 wages and property test can limit it further.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'What Is the QBI Deduction? (Qualified Business Income, 2025–2026)',
  description,
  author: { '@type': 'Organization', name: '1099 Estimator' },
  publisher: { '@type': 'Organization', name: '1099 Estimator', url: 'https://1099estimator.com' },
  mainEntityOfPage: 'https://1099estimator.com/guides/qbi-deduction',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://1099estimator.com' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://1099estimator.com/guides' },
    { '@type': 'ListItem', position: 3, name: 'QBI Deduction', item: 'https://1099estimator.com/guides/qbi-deduction' },
  ],
};
---

<Layout title={title} description={description} schema={[articleSchema, faqSchema, breadcrumbSchema]}>
  <article class="mx-auto max-w-3xl px-5 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-700">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/guides" class="hover:text-indigo-700">Guides</a>
      <span class="mx-1.5">/</span>
      <span class="text-slate-600">QBI deduction</span>
    </nav>

    <header class="mt-6">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-indigo-700 bg-indigo-100/80 ring-1 ring-indigo-200 rounded-full px-3 py-1">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span> Updated for the 2025 &amp; 2026 tax years
      </span>
      <h1 class="mt-5 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 text-balance">
        What is the QBI deduction?
      </h1>
      <p class="mt-4 text-lg text-slate-500 leading-relaxed">
        If you earn 1099 or other self-employed income, the Qualified Business Income deduction can quietly cut up to
        20% off the profit you pay federal income tax on. Here is what it is, who qualifies, and how the limits work.
      </p>
    </header>

    <div class="mt-10 space-y-10 text-slate-600 leading-relaxed">
      <section>
        <h2 class="text-2xl font-bold text-slate-900">The 20% deduction, explained</h2>
        <p class="mt-4">
          The <strong>Qualified Business Income (QBI) deduction</strong> — sometimes called the Section 199A deduction or
          the &ldquo;pass-through&rdquo; deduction — lets eligible business owners deduct up to <strong>20% of their
          qualified business income</strong> from their taxable income. It was created by the 2017 Tax Cuts and Jobs Act
          to give small businesses and the self-employed a break comparable to the corporate tax cut that arrived at the
          same time.
        </p>
        <p class="mt-4">
          &ldquo;Qualified business income&rdquo; is essentially the net profit from your trade or business — your revenue
          minus your deductible business expenses. If you run that profit through your personal return (as a sole
          proprietor, freelancer, single-member LLC, partnership, or S-corporation owner), it is <em>pass-through</em>
          income, and it generally qualifies. The deduction is taken on your Form 1040 and does not require itemizing —
          you can claim it and still take the standard deduction.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-900">Important: it lowers income tax, not SE tax</h2>
        <p class="mt-4">
          This is the single most misunderstood part of the QBI deduction. It reduces your <strong>federal income
          tax only</strong>. It does <strong>not</strong> reduce the <strong>15.3% self-employment tax</strong> you owe on
          your net profit. Self-employment tax (Social Security and Medicare) is calculated on 92.35% of your net profit
          <em>before</em> any QBI deduction is applied — so the two are completely separate calculations.
        </p>
        <p class="mt-4">
          In practice that means the QBI deduction shrinks the income-tax layer of your bill while the self-employment-tax
          layer stays exactly the same. Our
          <a href="/" class="text-indigo-600 font-medium underline decoration-indigo-200 hover:decoration-indigo-500">1099 tax calculator</a>
          has a QBI toggle so you can see both layers side by side and watch how the deduction changes only the income-tax
          portion.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-900">How the deduction is calculated</h2>
        <p class="mt-4">
          For most freelancers the math is refreshingly simple, but there is one cap to know. Your QBI deduction is the
          <strong>lesser</strong> of these two amounts:
        </p>
        <ul class="mt-4 space-y-2.5">
          <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></span><span><strong>20% of your qualified business income</strong> (your net business profit), or</span></li>
          <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></span><span><strong>20% of your taxable income</strong> minus any net capital gains.</span></li>
        </ul>
        <p class="mt-4">
          The second limit stops the deduction from wiping out income you have already sheltered with other deductions.
          For someone whose business profit is their main income, the first number usually wins. Above certain
          income thresholds, an additional test based on the <strong>W-2 wages you pay and the business property you
          own</strong> can further limit the deduction — but that mainly affects higher earners with employees.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-900">A worked example</h2>
        <div class="mt-6 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-6">
          <h3 class="font-bold text-slate-900">$68,000 of qualified profit</h3>
          <p class="mt-3 text-sm">
            Suppose you are a freelancer with <strong>$68,000</strong> in qualified business profit for the year, and your
            taxable income is comfortably above that once other income is counted, so the taxable-income cap is not the
            limiting factor.
          </p>
          <ul class="mt-4 space-y-1.5 text-sm">
            <li>Qualified business income: <strong>$68,000</strong></li>
            <li>QBI deduction (20% &times; $68,000): <strong>about $9,489</strong>*</li>
            <li>Income now taxed after QBI: <strong>$68,000 &minus; $9,489 = $58,511</strong></li>
          </ul>
          <p class="mt-4 text-sm text-slate-500">
            *The deduction is figured on the lesser of your qualified profit or 20% of taxable income, so the exact dollar
            amount depends on your full return — this matches the figure shown by our calculator&rsquo;s QBI toggle.
            Remember: that roughly $9,489 comes off your <em>income-tax</em> base only. Your self-employment tax on the
            $68,000 is unchanged.
          </p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-900">Income thresholds and the SSTB limit</h2>
        <p class="mt-4">
          Below an annually adjusted taxable-income threshold, almost everyone gets the clean 20% with no complications.
          The threshold is <strong>indexed for inflation every year</strong> and sits <strong>around the
          mid-$190,000s for single filers</strong> (roughly double that for married couples filing jointly). Under it, the
          type of work you do does not matter.
        </p>
        <p class="mt-4">
          Once your taxable income climbs above that threshold and into the phase-out range, the rules tighten in two ways:
        </p>
        <ul class="mt-4 space-y-2.5">
          <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></span><span>The <strong>W-2 wages and property test</strong> kicks in, potentially capping the deduction based on wages you pay employees and the cost of qualified business property.</span></li>
          <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></span><span>If your business is a <strong>specified service trade or business (SSTB)</strong>, the deduction begins to phase out and is <strong>fully eliminated</strong> once your income clears the top of the range.</span></li>
        </ul>
        <p class="mt-4">
          An <strong>SSTB</strong> is a field where the business&rsquo;s main asset is the reputation or skill of the
          people who run it — this includes <strong>consulting, law, accounting, health, and financial services</strong>,
          among others. If you are an SSTB owner with high taxable income, you may get a reduced deduction or none at all;
          below the threshold, SSTB owners get the full 20% just like anyone else. Because the exact dollar thresholds move
          with inflation each year, always confirm the current figures for your filing status before relying on them.
        </p>
      </section>

      <!-- FAQ -->
      <section id="faq">
        <h2 class="text-2xl font-bold text-slate-900">Frequently asked questions</h2>
        <div class="mt-6 space-y-3">
          {faqs.map((f) => (
            <details class="group rounded-2xl border border-slate-200 bg-white px-5 open:shadow-sm transition">
              <summary class="flex justify-between items-center cursor-pointer list-none font-semibold text-slate-800 py-4">
                {f.q}
                <span class="ml-4 shrink-0 grid place-items-center w-6 h-6 rounded-full bg-slate-100 text-slate-500 group-open:bg-indigo-100 group-open:text-indigo-700 group-open:rotate-45 transition">+</span>
              </summary>
              <p class="text-slate-600 leading-relaxed pb-5 -mt-1">{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <div class="rounded-2xl bg-indigo-50 border border-indigo-100 p-6 text-center">
        <h2 class="text-xl font-bold text-slate-900">See your QBI deduction in action</h2>
        <p class="mt-2 text-slate-600">Enter your 1099 income and expenses, flip on the QBI toggle, and watch your income-tax estimate drop.</p>
        <a href="/" class="mt-4 inline-flex items-center gap-1.5 rounded-xl bg-indigo-600 text-white font-semibold px-5 py-3 hover:bg-indigo-700 transition">Open the 1099 tax calculator →</a>
      </div>

      <!-- Related guides -->
      <section>
        <h2 class="text-lg font-bold text-slate-900">Related guides</h2>
        <ul class="mt-4 space-y-2">
          <li><a href="/guides/self-employed-tax-deductions" class="text-indigo-600 hover:text-indigo-800 underline decoration-indigo-200 hover:decoration-indigo-500">Top tax deductions for the self-employed</a></li>
          <li><a href="/guides/self-employment-tax-explained" class="text-indigo-600 hover:text-indigo-800 underline decoration-indigo-200 hover:decoration-indigo-500">Self-employment tax explained</a></li>
          <li><a href="/guides/quarterly-estimated-taxes" class="text-indigo-600 hover:text-indigo-800 underline decoration-indigo-200 hover:decoration-indigo-500">How to pay quarterly estimated taxes</a></li>
        </ul>
      </section>

      <p class="text-xs text-slate-400 leading-relaxed border-t border-slate-100 pt-6">
        Disclaimer: This guide is for educational purposes only and does not constitute tax, legal, or financial advice.
        Tax rules change and individual situations vary. Verify details with the IRS or a qualified tax professional
        before making decisions.
      </p>
    </div>
  </article>
</Layout>
